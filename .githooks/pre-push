#!/usr/bin/env bash
# Pre-push hook: runs the same checks as GitHub Actions ci.yml before
# letting the push reach the remote. Set up once per clone with:
#
#   git config core.hooksPath .githooks
#
# Bypass for emergencies with `--no-verify` or `SKIP_PREFLIGHT=1`.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
STAMP="${REPO_ROOT}/target/.preflight/last-commit"

if [[ -f "$STAMP" ]] && [[ "$(cat "$STAMP")" == "$(git rev-parse HEAD)" ]]; then
    printf '\033[32m[pre-push] preflight already passed for %s — skipping\033[0m\n' "$(git rev-parse --short HEAD)" >&2
    exit 0
fi

exec "${REPO_ROOT}/scripts/preflight.sh"
