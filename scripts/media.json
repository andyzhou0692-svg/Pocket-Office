[
  {
    "id": "screenshot",
    "kind": "render",
    "targets": ["docs"],
    "cols": 192, "rows": 64, "hour": 19, "day": 1,
    "theme": "normal", "scale": 2
  },
  {
    "id": "gallery",
    "kind": "crop",
    "targets": ["docs"],
    "from": "screenshot",
    "scale": 3,
    "quadrants": {
      "cubicle": [0.30, 0.00, 1.00, 0.55],
      "meeting":  [0.00, 0.00, 0.30, 0.55],
      "pantry":   [0.00, 0.49, 0.30, 1.00]
    }
  },
  {
    "id": "themes-composite",
    "kind": "composite",
    "targets": ["docs"],
    "over": "@themes.json",
    "slant": -0.20,
    "cols": 192, "rows": 64, "hour": 19, "day": 1
  },
  {
    "id": "reference",
    "kind": "render",
    "targets": ["docs"],
    "cols": 192, "rows": 64, "day": 1,
    "frames": [
      {"name": "reference-screenshot", "theme": "normal",    "hour": 19, "weather": "clear"},
      {"name": "reference-night",      "theme": "cyberpunk", "hour": 3,  "weather": "clear"}
    ]
  },
  {
    "id": "demo",
    "kind": "gif",
    "targets": ["docs"],
    "cols": 192, "rows": 64, "hour": 19, "day": 1,
    "theme": "normal", "duration": 15, "fps": 10, "colors": 128
  },
  {
    "id": "theme",
    "kind": "matrix",
    "targets": ["site"],
    "over": "@themes.json",
    "axis": "theme",
    "cols": 200, "rows": 90, "hour": 20
  },
  {
    "id": "weather",
    "kind": "matrix",
    "targets": ["site"],
    "over": "@weather.json",
    "axis": "weather",
    "cols": 200, "rows": 90, "hour": 15
  },
  {
    "id": "day",
    "kind": "render",
    "targets": ["site"],
    "cols": 200, "rows": 90, "hour": 13
  },
  {
    "id": "night",
    "kind": "render",
    "targets": ["site"],
    "cols": 200, "rows": 90, "hour": 22
  },
  {
    "id": "space",
    "kind": "crop",
    "targets": ["site"],
    "from": "day",
    "crops": {
      "cubicles": "800:620:680:430",
      "meeting":  "800:620:0:415",
      "pantry":   "800:620:0:775"
    }
  },
  {
    "id": "hero",
    "kind": "clip",
    "targets": ["site"],
    "cols": 208, "rows": 88,
    "duration": 20, "fps": 12, "hour": 17
  },
  {
    "id": "multi-floor",
    "kind": "clip",
    "targets": ["site"],
    "cols": 208, "rows": 88,
    "duration": 10, "fps": 15, "hour": 17,
    "extra": ["--max-desks", "16", "--agents", "22", "--navigate-at", "3:1", "--navigate-at", "7:0"]
  },
  {
    "id": "pets",
    "kind": "clip",
    "targets": ["site"],
    "cols": 208, "rows": 88,
    "duration": 12, "fps": 15, "hour": 14,
    "extra": ["--pets", "cat"]
  }
]
