---
import { SHOWCASE, showcaseVariants, showcaseGroups, floorById, floorName, asset } from '../consts';
import ChannelStage from './ChannelStage.astro';

const floor = floorById('showcase');
const channels = SHOWCASE.map((c, i) => ({
  ...c,
  ch: String(i + 1).padStart(2, '0'),
  variants: showcaseVariants(c),
  groups: showcaseGroups(c),
}));
const live = channels.filter((c) => c.status === 'live');
const def = channels.find((c) => c.default) ?? live[0];
// headline count derived from the dial itself — a hardcoded "Eight" desyncs
// the moment a channel is added or dropped. Deliberately counts ALL channels
// (the dial shows "soon" slots too) while the eyebrow counts live.length "on
// air" — the two diverge by design the day a soon-channel lands.
const COUNT_WORDS = [
  'Zero',
  'One',
  'Two',
  'Three',
  'Four',
  'Five',
  'Six',
  'Seven',
  'Eight',
  'Nine',
  'Ten',
  'Eleven',
  'Twelve',
];
const countWord = COUNT_WORDS[channels.length] ?? String(channels.length);
---

<section
  id={floor.id}
  class="showcase"
  data-lit
  data-floor={floor.fl}
  data-floor-label={floor.label}
>
  {
    /* the legacy #themes/#weather anchor spans + their hash map were removed in
      0.12.0 — #showcase-<id> is the one deep-link form (see fromHash below) */
  }
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{floor.fl} · {floorName(floor)} — {live.length} channels on air</p>
      <h2 class="statement statement--md">{countWord} channels.<br />One office.</h2>
      <p class="lead">
        The channel on screen is live — the same office running in your browser. Drag the clock
        forward, roll in a storm, switch the vibe. The other channels are recorded; flip a channel
        to watch them on the big screen.
      </p>
    </div>

    <div class="studio reveal" id="studio">
      <div class="studio__stages">
        {live.map((c) => <ChannelStage channel={c} active={c.id === def.id} />)}
      </div>
      <div class="dial" role="group" aria-label="Demo channels">
        {
          channels.map((c) =>
            c.status === 'live' ? (
              <button
                class="mon dial__ch"
                data-ch={c.id}
                aria-pressed={c.id === def.id ? 'true' : 'false'}
              >
                <span class="dial__num">{c.ch}</span> {c.label}
                {c.kind === 'live' && <small class="dial__live">live</small>}
              </button>
            ) : (
              <span class="dial__ch dial__ch--soon">
                <span class="dial__num">{c.ch}</span> {c.label} <small>soon</small>
              </span>
            )
          )
        }
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ wasmJsUrl: asset('wasm/pixtuoid_web.js') }}>
  (function () {
    const studio = document.getElementById('studio');
    if (!studio) return;
    const stages = studio.querySelectorAll('[data-stage]');
    const monitors = studio.querySelectorAll('button.mon[data-ch]');
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    let inView = false;

    // Retint the page's DECORATIVE hues to preview a theme — like hitting `t`
    // in the app. Deliberately NOT --coral-deep: that's the AA text color, and
    // a raw chip accent drops it below WCAG 1.4.3. Shared by the generic OSD
    // gallery chips below and the VIBING theme chips.
    function retintPage(accent, accent2) {
      const root = document.documentElement;
      root.style.setProperty('--coral', accent);
      root.style.setProperty('--amber', accent2 || accent);
    }

    // ---- lazy hydration: promote data-src media the first time a channel is
    // tuned or its monitor is hovered/focused (zero offscreen video bytes)
    function hydrate(stage) {
      stage.querySelectorAll('img[data-src]').forEach(function (img) {
        img.src = img.dataset.src;
        img.removeAttribute('data-src');
      });
      stage.querySelectorAll('video[data-mp4]').forEach(function (v) {
        // hidden channels defer their poster too (browsers fetch poster even on
        // [hidden] videos) — promote it alongside the sources on first tune/hover
        if (v.dataset.poster) {
          v.poster = v.dataset.poster;
          v.removeAttribute('data-poster');
        }
        if (v.dataset.webm) {
          const sw = document.createElement('source');
          sw.src = v.dataset.webm;
          sw.type = 'video/webm';
          v.appendChild(sw);
        }
        const sm = document.createElement('source');
        sm.src = v.dataset.mp4;
        sm.type = 'video/mp4';
        v.appendChild(sm);
        v.removeAttribute('data-mp4');
        v.removeAttribute('data-webm');
        v.load();
      });
    }

    // ---- play policy: a clip plays iff its stage is the tuned one AND the
    // studio is in view AND reduced-motion is off AND the office isn't paused
    // (WCAG 2.2.2 — the #office-pause button governs the clips too via the
    // pix:paused listener below). Under reduced-motion show native controls.
    let userPaused = false;
    function syncVideos() {
      stages.forEach(function (st) {
        const v = st.querySelector('video');
        if (!v) return;
        if (mq.matches) {
          v.removeAttribute('autoplay');
          v.pause();
          v.setAttribute('controls', '');
          return;
        }
        v.removeAttribute('controls');
        if (!st.hidden && inView && !userPaused && !v.dataset.mp4) {
          const p = v.play();
          if (p && p.catch) p.catch(function () {});
        } else {
          v.pause();
        }
      });
    }
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(
        function (entries) {
          inView = entries[0].isIntersecting;
          syncVideos();
          syncCanvas();
        },
        { threshold: 0.15 }
      ).observe(studio);
    }
    if (mq.addEventListener)
      mq.addEventListener('change', function () {
        syncVideos();
        syncCanvas();
      });
    // WCAG 2.2.2: the page-wide pause button (#office-pause) stops the looping
    // demo clips too — one control governs all >5s auto-motion. The clips carry
    // no visible controls in normal motion, so this IS their pause affordance.
    // #office-pause is shown whenever motion runs = NOT reduced-motion — including
    // the no-wasm / fetch-failure poster paths, where it's decoupled from the
    // office canvas and still governs the ticker / dust / clips (#456). Under
    // reduced-motion the button is hidden and the clips instead show native
    // <video> controls (the separate backstop above).
    document.addEventListener('pix:paused', function (e) {
      userPaused = !!(e.detail && e.detail.paused);
      syncVideos();
      syncCanvas();
    });
    syncVideos();

    // ---- VIBING channel: a live pixtuoid office (wasm) driven by the time
    // slider + weather/theme chips. `syncCanvas` mirrors syncVideos' gate —
    // active + visible + unpaused + motion allowed — and is called from the
    // SAME four sites syncVideos is (the pix:paused listener above, the
    // IntersectionObserver callback above, the mq change listener above, and
    // tune()'s swap() below). A separate wasm Office instance from
    // OfficeBackdrop's page-wide one (its own seed/timeline/weather/theme) —
    // the wasm module itself is browser-cached by URL, so booting here costs
    // no second fetch/compile.
    const vibingStage = studio.querySelector('[data-stage="vibing"]');
    const vibingCanvas = vibingStage && vibingStage.querySelector('[data-vibing-canvas]');
    const vibingTime = vibingStage && vibingStage.querySelector('[data-vibing-time]');
    const vibingTimeLabel = vibingStage && vibingStage.querySelector('[data-vibing-time-label]');
    const vibingTimeWrap = vibingStage && vibingStage.querySelector('.vibing__time');
    const vibingWeather =
      vibingStage && vibingStage.querySelector('.stage__osd[data-group="weather"]');
    const vibingTheme = vibingStage && vibingStage.querySelector('.stage__osd[data-group="theme"]');
    const VIBING_SEED = 11; // fixed u32 — distinct from OfficeBackdrop's page office (seed 3)
    let vWasm = null;
    let vOffice = null;
    let vCtx = null;
    let vImg = null;
    let vRaf = 0;
    let vBooted = false;
    // the slider's own rendered value is the one source of truth for the
    // initial hour — no second hardcoded "18" to drift from it.
    let scrubHour = vibingTime ? parseFloat(vibingTime.value) : 18;
    let vStart = Date.now();

    // The clock readout: the visible label AND `aria-valuetext`, so a screen
    // reader announces "18:00" instead of the raw 0–24 (0.5-step) range value.
    function updateClock(h) {
      // Slider max is 24 — wrap the hour so the top of the range reads 00:00,
      // not 24:00 (setHours(24) already rolls to next-day midnight).
      const hh = String(Math.floor(h) % 24).padStart(2, '0');
      const mm = String(Math.round((h % 1) * 60)).padStart(2, '0');
      const t = hh + ':' + mm;
      if (vibingTimeLabel) vibingTimeLabel.textContent = t;
      if (vibingTime) vibingTime.setAttribute('aria-valuetext', t);
    }
    updateClock(scrubHour);

    // Sky-scrubber phase: sun by day, moon after dusk. The day/night boundary is
    // the ENGINE's own SUN_RISE_H/SUN_SET_H window (Office.is_day, from sky.rs) —
    // NOT a second hardcoded copy in JS — so the slider's sun/moon can't drift
    // from the office it previews. Before the office boots, the SSR default
    // (`data-phase="day"`, matching the 18:00 start) holds; the phase then syncs
    // from the engine on boot and on every scrub.
    function setSliderPhase(h) {
      if (vibingTimeWrap && vOffice) {
        vibingTimeWrap.dataset.phase = vOffice.is_day(h) ? 'day' : 'night';
      }
    }

    function anchorForHour(h) {
      const d = new Date();
      d.setHours(Math.floor(h), Math.round((h % 1) * 60), 0, 0);
      return d.getTime();
    }
    function vPaint() {
      const now = anchorForHour(scrubHour) + (Date.now() - vStart);
      vOffice.step(now, vibingCanvas.width, vibingCanvas.height);
      // re-read ptr/len every frame — a resize/memory.grow moves them
      const view = new Uint8ClampedArray(
        vWasm.memory.buffer,
        vOffice.frame_ptr(),
        vOffice.frame_len()
      );
      if (view.length !== vImg.data.length) return;
      vImg.data.set(view);
      vCtx.putImageData(vImg, 0, 0);
    }
    function vFrame() {
      vRaf = 0;
      vPaint();
      vRaf = requestAnimationFrame(vFrame);
    }
    function startCanvas() {
      if (!vRaf && vOffice) vRaf = requestAnimationFrame(vFrame);
    }
    function stopCanvas() {
      if (vRaf) cancelAnimationFrame(vRaf);
      vRaf = 0;
    }
    function bootCanvas() {
      if (vBooted) return;
      vBooted = true;
      // Share ONE init promise with OfficeBackdrop's page-wide Office — the
      // generated glue's __wbg_init only memoizes the resolved instance, not
      // an in-flight promise, so two independent boots racing before either
      // resolves would instantiate two wasm instances and stomp the single
      // module-global `wasm` (see OfficeBackdrop.astro's `boot()` for the
      // full race + site/CLAUDE.md's VIBING entry).
      window.__pixWasm =
        window.__pixWasm ||
        import(wasmJsUrl).then(function (m) {
          return m.default().then(function () {
            return m;
          });
        });
      window.__pixWasm
        .then(function (mod) {
          // idempotent once resolved — hands back the shared exports/memory
          return mod.default().then(function (w) {
            vWasm = w;
            vOffice = new mod.Office(VIBING_SEED);
            // Apply the currently-active weather AND theme chips so the booted
            // office matches what the OSD reports. Weather: the `clear` chip is
            // is-active (matches vibing-poster.png, gen'd --weather clear) but a
            // fresh Office is weather_override=None (clock-based). Theme: a chip
            // clicked DURING this async boot skipped its `if (vOffice)` set_theme
            // yet still set is-active/aria-pressed + retinted — re-applying the
            // active theme here keeps aria-pressed consistent with the rendered
            // office (WCAG 4.1.2); `normal` (the default) is a harmless no-op.
            const w0 = vibingStage.querySelector('.osd__chip[data-weather].is-active');
            if (w0) vOffice.set_weather(w0.dataset.weather);
            const t0 = vibingStage.querySelector('.osd__chip[data-theme].is-active');
            if (t0) vOffice.set_theme(t0.dataset.theme);
            // Engine is live now → sync the slider's sun/moon to it (the SSR
            // `data-phase` default held until this point).
            setSliderPhase(scrubHour);
            vCtx = vibingCanvas.getContext('2d');
            vImg = vCtx.createImageData(vibingCanvas.width, vibingCanvas.height);
            syncCanvas(); // gating may have moved on while the fetch was in flight
          });
        })
        .catch(function () {
          // wasm never loaded: leave the poster showing, no loop
        });
    }
    function syncCanvas() {
      if (!vibingStage || !vibingCanvas) return;
      const run = !vibingStage.hidden && inView && !userPaused && !mq.matches;
      if (run) {
        if (!vOffice) bootCanvas();
        else startCanvas();
      } else {
        stopCanvas();
      }
    }
    if (vibingTime) {
      vibingTime.addEventListener('input', function () {
        scrubHour = parseFloat(vibingTime.value);
        updateClock(scrubHour);
        setSliderPhase(scrubHour);
        vStart = Date.now(); // re-anchor: the office keeps living at this hour
      });
    }
    if (vibingWeather) {
      vibingWeather.addEventListener('click', function (e) {
        const chip = e.target.closest('.osd__chip[data-weather]');
        if (!chip) return;
        if (vOffice) vOffice.set_weather(chip.dataset.weather);
        vibingWeather.querySelectorAll('.osd__chip').forEach(function (x) {
          const on = x === chip;
          x.classList.toggle('is-active', on);
          x.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
      });
    }
    if (vibingTheme) {
      vibingTheme.addEventListener('click', function (e) {
        const chip = e.target.closest('.osd__chip[data-theme]');
        if (!chip) return;
        if (vOffice) vOffice.set_theme(chip.dataset.theme);
        vibingTheme.querySelectorAll('.osd__chip').forEach(function (x) {
          const on = x === chip;
          x.classList.toggle('is-active', on);
          x.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        if (vibingTheme.dataset.retint && chip.dataset.accent) {
          retintPage(chip.dataset.accent, chip.dataset.accent2);
        }
      });
      if (vibingTheme.dataset.retint) {
        // a real theme change elsewhere (Nav toggle / Escape / dracula egg /
        // the `t` key) clears this preview's pressed state — same contract as
        // the generic gallery chips below (neither dispatches pix:theme
        // itself: this IS a decorative preview, not the real site theme, and
        // dispatching it would immediately self-clear the is-active state
        // just set above, plus wrongly tell Base.astro's listener a real
        // theme change happened).
        document.addEventListener('pix:theme', function () {
          vibingTheme.querySelectorAll('.osd__chip').forEach(function (x) {
            x.classList.remove('is-active');
            x.setAttribute('aria-pressed', 'false');
          });
        });
      }
    }

    // ---- channel tuning (hidden-swap; view-transition crossfade when available)
    function tune(id, silent) {
      const next = studio.querySelector('[data-stage="' + id + '"]');
      if (!next || !next.hidden) return;
      hydrate(next);
      function swap() {
        stages.forEach(function (s) {
          s.hidden = s !== next;
        });
        monitors.forEach(function (m) {
          m.setAttribute('aria-pressed', m.dataset.ch === id ? 'true' : 'false');
        });
        syncVideos();
        syncCanvas();
      }
      if (!mq.matches && document.startViewTransition) document.startViewTransition(swap);
      else swap();
      if (!silent) history.replaceState(null, '', '#showcase-' + id);
    }
    monitors.forEach(function (m) {
      m.addEventListener('click', function () {
        tune(m.dataset.ch);
      });
      function warm() {
        const st = studio.querySelector('[data-stage="' + m.dataset.ch + '"]');
        if (st) hydrate(st);
      }
      m.addEventListener('pointerenter', warm);
      m.addEventListener('focus', warm);
    });

    // ---- OSD chips (variant-set channels) — the old gallery JS, parameterized
    stages.forEach(function (st) {
      const img = st.querySelector('img.terminal__screen');
      const title = st.querySelector('[data-stage-title]');
      // .osd__chip is reused by the VIBING live channel's weather/theme groups
      // too (data-weather/data-theme, no data-src) — filter to the variant-set
      // chips this loop drives; the VIBING controller above owns its own.
      const chips = Array.prototype.filter.call(st.querySelectorAll('.osd__chip'), function (c) {
        return !!c.dataset.src;
      });
      if (!chips.length || !img) return;
      const prefetched = {};
      function prefetch(src) {
        if (src && !prefetched[src]) {
          prefetched[src] = new Image();
          prefetched[src].src = src;
        }
      }
      chips.forEach(function (c) {
        c.addEventListener('pointerenter', function () {
          prefetch(c.dataset.src);
        });
        c.addEventListener('click', function () {
          img.src = c.dataset.src;
          img.alt = c.dataset.alt;
          if (title) title.textContent = c.dataset.title;
          if (c.dataset.accent) st.style.setProperty('--accent', c.dataset.accent);
          if (st.dataset.retint) retintPage(c.dataset.accent, c.dataset.accent2);
          st.classList.remove('retint-pulse');
          void st.offsetWidth;
          st.classList.add('retint-pulse');
          chips.forEach(function (x) {
            const on = x === c;
            x.classList.toggle('is-active', on);
            x.setAttribute('aria-pressed', on ? 'true' : 'false');
          });
        });
      });
      if (st.dataset.retint) {
        // a non-gallery theme change (Nav toggle / Escape / dracula egg) clears
        // the retint, so no chip should still read as active/pressed
        document.addEventListener('pix:theme', function () {
          chips.forEach(function (x) {
            x.classList.remove('is-active');
            x.setAttribute('aria-pressed', 'false');
          });
        });
      }
    });

    // ---- deep links: #showcase-<id> (the legacy #themes/#weather map was
    // dropped in 0.12.0 — those inbound links now just don't scroll/tune,
    // like any unknown fragment; the canonical form is what tune() writes)
    function fromHash() {
      const h = location.hash;
      const id = h.indexOf('#showcase-') === 0 ? h.slice('#showcase-'.length) : null;
      if (!id) return;
      const exists = studio.querySelector('[data-stage="' + id + '"]');
      if (!exists) return;
      tune(id, true);
      // #showcase-<id> matches no element id, so the browser never scrolls on
      // its own — bring the studio into view.
      const sec = document.getElementById('showcase');
      if (sec) sec.scrollIntoView({ behavior: mq.matches ? 'auto' : 'smooth', block: 'start' });
    }
    fromHash();
    window.addEventListener('hashchange', fromHash);
  })();
</script>

<style>
  .dial {
    /* aligned columns, not ragged inline flow — the numbered labels imply a grid */
    display: grid;
    grid-template-columns: repeat(3, max-content);
    gap: 0.4rem 1.6rem;
    margin-top: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.92rem;
  }
  @media (max-width: 480px) {
    /* 3× max-content is ~376px — past a 360/390px phone, so the studio's
       overflow-x:clip would hide the right dial column (03 Dashboard / 06 Spaces,
       untappable). Wrap to two shrinkable columns so all 7 channels stay on-screen. */
    .dial {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.4rem 1rem;
    }
  }
  .dial__ch {
    text-align: left;
  }
  @media (pointer: coarse) {
    /* lift the row pitch toward the 44px thumb target — 0.55rem left adjacent
       channels ~41px centre-to-centre (mis-tap range). */
    .dial__ch {
      padding-block: 0.7rem;
    }
  }
  .dial__ch {
    background: none;
    border: 0;
    padding: 0.3rem 0.2rem;
    font: inherit;
    color: var(--fg-muted);
    cursor: pointer;
    transition: color 0.18s ease;
  }
  .dial__ch:hover,
  .dial__ch:focus-visible {
    color: var(--fg);
  }
  .dial__ch[aria-pressed='true'] {
    color: var(--fg);
  }
  .dial__ch[aria-pressed='true'] .dial__num {
    color: var(--led);
    text-shadow: 0 0 6px var(--led-glow);
  }
  .dial__num {
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .dial__ch--soon {
    color: color-mix(in srgb, var(--fg-muted) 55%, transparent);
    cursor: default;
  }
  /* the dial's two small appended status tags share one geometry (pinned here
     so a size tweak can't drift): "soon" dims a placeholder channel; "live"
     LED-glows the one INTERACTIVE channel (kind:"live") apart from the clips. */
  .dial__ch--soon small,
  .dial__live {
    font-size: 0.72em;
    letter-spacing: 0.08em;
  }
  .dial__live {
    color: var(--led);
    text-shadow: 0 0 6px var(--led-glow);
  }

  .showcase {
    position: relative;
    /* inherit section's clamp(3.2rem,7vw,6rem)=96px — the lone 80px override was
       an unexplained dip in an otherwise strict cadence (HowItWorks also follows
       an office-gap and keeps 96px). */
  }
  /* Mobile only: at narrow widths the kicker + heading wrap onto more lines and
     scroll into view while still low in the viewport — far from the dimmer's
     center-line, so its distance-based ease (OfficeBackdrop's recompute()) hasn't
     engaged yet and the text crosses bare office floor unplated for a stretch of
     scroll (clean only once the block nears center). Desktop's shorter content
     reaches center — and a real dimmer level — by the time it's visible at all,
     so it never shows this gap. Give the section head the same guaranteed-floor
     scrim idiom Hero/Features/Install already lean on (same padding/margin-inline
     cancel as .text-scrim, reused directly rather than via the class since it
     wraps the whole head, not one paragraph). */
  @media (max-width: 760px) {
    .section-head {
      background: var(--scrim);
      border: 1px solid var(--border-strong);
      padding: 0.75rem;
      margin-inline: -0.75rem;
    }
  }
  .studio {
    display: grid;
    /* the single mobile column must shrink below its content's min-width (the
       dial's tracks), or a child drags the grid past the viewport and the
       section's overflow-x:clip cuts off the overflow with no scroll */
    grid-template-columns: minmax(0, 1fr);
    gap: 1.4rem;
  }
  @media (min-width: 980px) {
    .studio {
      grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
      align-items: start;
    }
  }
  .studio__stages {
    min-width: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    /* the VIBING channel's controls only make sense with the office running,
       and reduced-motion never boots it (poster only) — hide them. :global
       because .vibing__time/.stage__osd are ChannelStage's own markup, not
       this component's template (Astro scopes styles per-component). */
    :global([data-stage='vibing'] .vibing__time),
    :global([data-stage='vibing'] .stage__osd) {
      display: none;
    }
  }
</style>
