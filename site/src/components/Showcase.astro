---
import { SHOWCASE, showcaseVariants, floorByNumber } from '../consts';
import ChannelStage from './ChannelStage.astro';

const floor = floorByNumber(5);
const channels = SHOWCASE.map((c, i) => ({
  ...c,
  ch: String(i + 1).padStart(2, '0'),
  variants: showcaseVariants(c),
}));
const live = channels.filter((c) => c.status === 'live');
const def = channels.find((c) => c.default) ?? live[0];
// headline count derived from the dial itself — a hardcoded "Eight" desyncs
// the moment a channel is added or dropped. Deliberately counts ALL channels
// (the dial shows "soon" slots too) while the eyebrow counts live.length "on
// air" — the two diverge by design the day a soon-channel lands.
const COUNT_WORDS = [
  'Zero',
  'One',
  'Two',
  'Three',
  'Four',
  'Five',
  'Six',
  'Seven',
  'Eight',
  'Nine',
  'Ten',
  'Eleven',
  'Twelve',
];
const countWord = COUNT_WORDS[channels.length] ?? String(channels.length);
---

<section id={floor.id} class="showcase" data-lit data-floor={floor.n}>
  {
    /* the legacy #themes/#weather anchor spans + their hash map were removed in
      0.12.0 — #showcase-<id> is the one deep-link form (see fromHash below) */
  }
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{floor.n}F · {floor.name} — {live.length} channels on air</p>
      <h2 class="statement statement--md">{countWord} channels.<br />One office.</h2>
      <p class="lead">
        The office, channel by channel — flip a channel to switch the big screen. Themes and weather
        expose their dials on-screen.
      </p>
    </div>

    <div class="studio reveal" id="studio">
      <div class="studio__stages">
        {live.map((c) => <ChannelStage channel={c} active={c.id === def.id} />)}
      </div>
      <div class="dial" role="group" aria-label="Demo channels">
        {
          channels.map((c) =>
            c.status === 'live' ? (
              <button
                class="mon dial__ch"
                data-ch={c.id}
                aria-pressed={c.id === def.id ? 'true' : 'false'}
              >
                <span class="dial__num">{c.ch}</span> {c.label}
              </button>
            ) : (
              <span class="dial__ch dial__ch--soon">
                <span class="dial__num">{c.ch}</span> {c.label} <small>soon</small>
              </span>
            )
          )
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const studio = document.getElementById('studio');
    if (!studio) return;
    const stages = studio.querySelectorAll('[data-stage]');
    const monitors = studio.querySelectorAll('button.mon[data-ch]');
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    let inView = false;

    // ---- lazy hydration: promote data-src media the first time a channel is
    // tuned or its monitor is hovered/focused (zero offscreen video bytes)
    function hydrate(stage) {
      stage.querySelectorAll('img[data-src]').forEach(function (img) {
        img.src = img.dataset.src;
        img.removeAttribute('data-src');
      });
      stage.querySelectorAll('video[data-mp4]').forEach(function (v) {
        // hidden channels defer their poster too (browsers fetch poster even on
        // [hidden] videos) — promote it alongside the sources on first tune/hover
        if (v.dataset.poster) {
          v.poster = v.dataset.poster;
          v.removeAttribute('data-poster');
        }
        if (v.dataset.webm) {
          const sw = document.createElement('source');
          sw.src = v.dataset.webm;
          sw.type = 'video/webm';
          v.appendChild(sw);
        }
        const sm = document.createElement('source');
        sm.src = v.dataset.mp4;
        sm.type = 'video/mp4';
        v.appendChild(sm);
        v.removeAttribute('data-mp4');
        v.removeAttribute('data-webm');
        v.load();
      });
    }

    // ---- play policy: a clip plays iff its stage is the tuned one AND the
    // studio is in view AND reduced-motion is off AND the office isn't paused
    // (WCAG 2.2.2 — the #office-pause button governs the clips too via the
    // pix:paused listener below). Under reduced-motion show native controls.
    let userPaused = false;
    function syncVideos() {
      stages.forEach(function (st) {
        const v = st.querySelector('video');
        if (!v) return;
        if (mq.matches) {
          v.removeAttribute('autoplay');
          v.pause();
          v.setAttribute('controls', '');
          return;
        }
        v.removeAttribute('controls');
        if (!st.hidden && inView && !userPaused && !v.dataset.mp4) {
          const p = v.play();
          if (p && p.catch) p.catch(function () {});
        } else {
          v.pause();
        }
      });
    }
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(
        function (entries) {
          inView = entries[0].isIntersecting;
          syncVideos();
        },
        { threshold: 0.15 }
      ).observe(studio);
    }
    if (mq.addEventListener) mq.addEventListener('change', syncVideos);
    // WCAG 2.2.2: the page-wide pause button (#office-pause) stops the looping
    // demo clips too — one control governs all >5s auto-motion. The clips carry
    // no visible controls in normal motion, so this IS their pause affordance.
    // #office-pause is shown whenever motion runs = NOT reduced-motion — including
    // the no-wasm / fetch-failure poster paths, where it's decoupled from the
    // office canvas and still governs the ticker / dust / clips (#456). Under
    // reduced-motion the button is hidden and the clips instead show native
    // <video> controls (the separate backstop above).
    document.addEventListener('pix:paused', function (e) {
      userPaused = !!(e.detail && e.detail.paused);
      syncVideos();
    });
    syncVideos();

    // ---- channel tuning (hidden-swap; view-transition crossfade when available)
    function tune(id, silent) {
      const next = studio.querySelector('[data-stage="' + id + '"]');
      if (!next || !next.hidden) return;
      hydrate(next);
      function swap() {
        stages.forEach(function (s) {
          s.hidden = s !== next;
        });
        monitors.forEach(function (m) {
          m.setAttribute('aria-pressed', m.dataset.ch === id ? 'true' : 'false');
        });
        syncVideos();
      }
      if (!mq.matches && document.startViewTransition) document.startViewTransition(swap);
      else swap();
      if (!silent) history.replaceState(null, '', '#showcase-' + id);
    }
    monitors.forEach(function (m) {
      m.addEventListener('click', function () {
        tune(m.dataset.ch);
      });
      function warm() {
        const st = studio.querySelector('[data-stage="' + m.dataset.ch + '"]');
        if (st) hydrate(st);
      }
      m.addEventListener('pointerenter', warm);
      m.addEventListener('focus', warm);
    });

    // ---- OSD chips (variant-set channels) — the old gallery JS, parameterized
    stages.forEach(function (st) {
      const img = st.querySelector('img.terminal__screen');
      const title = st.querySelector('[data-stage-title]');
      const chips = st.querySelectorAll('.osd__chip');
      if (!chips.length || !img) return;
      const prefetched = {};
      function prefetch(src) {
        if (src && !prefetched[src]) {
          prefetched[src] = new Image();
          prefetched[src].src = src;
        }
      }
      chips.forEach(function (c) {
        c.addEventListener('pointerenter', function () {
          prefetch(c.dataset.src);
        });
        c.addEventListener('click', function () {
          img.src = c.dataset.src;
          img.alt = c.dataset.alt;
          if (title) title.textContent = c.dataset.title;
          if (c.dataset.accent) st.style.setProperty('--accent', c.dataset.accent);
          if (st.dataset.retint) {
            // Retint the page's DECORATIVE hues to preview this theme — like
            // hitting `t` in the app. Deliberately NOT --coral-deep: that's the
            // AA text color, and a raw chip accent drops it below WCAG 1.4.3.
            const root = document.documentElement;
            root.style.setProperty('--coral', c.dataset.accent);
            root.style.setProperty('--amber', c.dataset.accent2 || c.dataset.accent);
          }
          st.classList.remove('retint-pulse');
          void st.offsetWidth;
          st.classList.add('retint-pulse');
          chips.forEach(function (x) {
            const on = x === c;
            x.classList.toggle('is-active', on);
            x.setAttribute('aria-pressed', on ? 'true' : 'false');
          });
        });
      });
      if (st.dataset.retint) {
        // a non-gallery theme change (Nav toggle / Escape / dracula egg) clears
        // the retint, so no chip should still read as active/pressed
        document.addEventListener('pix:theme', function () {
          chips.forEach(function (x) {
            x.classList.remove('is-active');
            x.setAttribute('aria-pressed', 'false');
          });
        });
      }
    });

    // ---- deep links: #showcase-<id> (the legacy #themes/#weather map was
    // dropped in 0.12.0 — those inbound links now just don't scroll/tune,
    // like any unknown fragment; the canonical form is what tune() writes)
    function fromHash() {
      const h = location.hash;
      const id = h.indexOf('#showcase-') === 0 ? h.slice('#showcase-'.length) : null;
      if (!id) return;
      const exists = studio.querySelector('[data-stage="' + id + '"]');
      if (!exists) return;
      tune(id, true);
      // #showcase-<id> matches no element id, so the browser never scrolls on
      // its own — bring the studio into view.
      const sec = document.getElementById('showcase');
      if (sec) sec.scrollIntoView({ behavior: mq.matches ? 'auto' : 'smooth', block: 'start' });
    }
    fromHash();
    window.addEventListener('hashchange', fromHash);
  })();
</script>

<style>
  .dial {
    /* aligned columns, not ragged inline flow — the numbered labels imply a grid */
    display: grid;
    grid-template-columns: repeat(3, max-content);
    gap: 0.4rem 1.6rem;
    margin-top: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.92rem;
  }
  @media (max-width: 480px) {
    /* 3× max-content is ~376px — past a 360/390px phone, so the studio's
       overflow-x:clip would hide the right dial column (03 Dashboard / 06 Spaces,
       untappable). Wrap to two shrinkable columns so all 8 channels stay on-screen. */
    .dial {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.4rem 1rem;
    }
  }
  .dial__ch {
    text-align: left;
  }
  @media (pointer: coarse) {
    .dial__ch {
      padding-block: 0.55rem;
    }
  }
  .dial__ch {
    background: none;
    border: 0;
    padding: 0.3rem 0.2rem;
    font: inherit;
    color: var(--fg-muted);
    cursor: pointer;
  }
  .dial__ch:hover,
  .dial__ch:focus-visible {
    color: var(--fg);
  }
  .dial__ch[aria-pressed='true'] {
    color: var(--fg);
  }
  .dial__ch[aria-pressed='true'] .dial__num {
    color: var(--led);
    text-shadow: 0 0 6px var(--led-glow);
  }
  .dial__num {
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .dial__ch--soon {
    color: color-mix(in srgb, var(--fg-muted) 55%, transparent);
    cursor: default;
  }
  .dial__ch--soon small {
    font-size: 0.72em;
    letter-spacing: 0.08em;
  }

  .showcase {
    position: relative;
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }
  .studio {
    display: grid;
    /* the single mobile column must shrink below its content's min-width (the
       dial's tracks), or a child drags the grid past the viewport and the
       section's overflow-x:clip cuts off the overflow with no scroll */
    grid-template-columns: minmax(0, 1fr);
    gap: 1.4rem;
  }
  @media (min-width: 980px) {
    .studio {
      grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
      align-items: start;
    }
  }
  .studio__stages {
    min-width: 0;
  }
</style>
