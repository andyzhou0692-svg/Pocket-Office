---
// The app's neon wall-ticker, fed with REAL provenance at build time: the most
// recently merged PRs of this repo — which are themselves authored by coding
// agents working in this office. Falls back to the canned reel when the API is
// unreachable (offline dev, rate limit) so the build never fails or blocks.
const FALLBACK = [
  { state: 'active', who: 'claude-code', what: 'editing src/reducer.rs' },
  { state: 'waiting', who: 'codex', what: 'awaiting approval' },
  { state: 'active', who: 'claude-code', what: 'walking to the pantry ☕' },
  { state: 'active', who: 'codex', what: 'running cargo test' },
  { state: 'idle', who: 'cursor', what: 'idle at desk' },
  // a real line from the meeting room's chitchat corpus (tui/chitchat.rs)
  { state: 'active', who: 'meeting room', what: '“it’s DNS” · “blame git”' },
  { state: 'active', who: 'claude-code', what: 'git commit -m "feat: ..."' },
];

interface TickerItem {
  state: string;
  who: string;
  what: string;
}

let items: TickerItem[] = FALLBACK;
try {
  // Unauthenticated is fine (one request per build, 60/h limit); CI can pass
  // GITHUB_TOKEN for headroom. 5s timeout keeps a hung API from stalling builds.
  const headers: Record<string, string> = { accept: 'application/vnd.github+json' };
  if (process.env.GITHUB_TOKEN) headers.authorization = `Bearer ${process.env.GITHUB_TOKEN}`;
  const res = await fetch(
    'https://api.github.com/repos/IvanWng97/pixtuoid/pulls?state=closed&base=main&sort=updated&direction=desc&per_page=12',
    { headers, signal: AbortSignal.timeout(5000) }
  );
  if (res.ok) {
    const prs = (await res.json()) as { number: number; title: string; merged_at: string | null }[];
    const merged = prs.filter((p) => p.merged_at).slice(0, 6);
    // Below 4 the loop reads as broken — keep the canned reel instead.
    if (merged.length >= 4) {
      // Strip the conventional-commit prefix (the visitor-facing voice is the
      // change, not its taxonomy) and truncate on a word boundary.
      const human = (title: string) => {
        const t = title.replace(/^[a-z]+(\([^)]*\))?!?:\s*/, '');
        if (t.length <= 64) return t;
        const cut = t.slice(0, 63);
        return cut.slice(0, Math.max(40, cut.lastIndexOf(' '))) + '…';
      };
      const real: TickerItem[] = merged.map((p, i) => ({
        // vary the dots like a live wall would — merged work isn't all-green
        state: ['active', 'active', 'idle'][i % 3],
        who: 'cc·pixtuoid',
        what: `merged #${p.number} · ${human(p.title)}`,
      }));
      // Interleave office-life beats between the real PRs: authenticity AND the
      // product's voice — all-real read as a dull commit feed in review.
      const flavor = FALLBACK.filter((f) => f.who !== 'cursor');
      items = real.flatMap((r, i) => (i % 2 === 1 ? [flavor[(i >> 1) % flavor.length], r] : [r]));
    }
  }
} catch {
  // offline / timeout → FALLBACK already in place
}
---

<div class="ticker" aria-hidden="true">
  <div class="ticker__track">
    {
      [0, 1].map(() =>
        items.map((it) => (
          <span class="ticker__item">
            <span class:list={['ticker__dot', it.state]} />
            <b>{it.who}</b> · {it.what}
          </span>
        ))
      )
    }
  </div>
</div>

<style>
  .ticker {
    overflow: hidden;
    white-space: nowrap;
    border-block: 1px solid var(--border);
    background: var(--bg-tint);
  }
  .ticker__track {
    display: inline-flex;
    padding: 0.55rem 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-muted);
    animation: ticker 38s linear infinite;
    will-change: transform;
  }
  .ticker__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-right: 2.6rem;
  }
  .ticker__item b {
    color: var(--fg);
    font-weight: 700;
  }
  .ticker__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: none;
  }
  .ticker__dot.active {
    background: var(--green);
  }
  .ticker__dot.waiting {
    background: var(--amber);
  }
  .ticker__dot.idle {
    background: var(--gray);
  }
  @keyframes ticker {
    to {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker__track {
      animation: none;
    }
  }
</style>
