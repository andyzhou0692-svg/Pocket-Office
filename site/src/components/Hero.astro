---
import { REPO, floorByNumber } from '../consts';

const floor = floorByNumber(6);
---

<section id={floor.id} class="hero" data-floor={floor.n}>
  {
    /* The title card: the live office (page-wide backdrop) is fully lit at
      scroll-0; the statement sits bottom-left, film-title style, and pulls
      the dimmer in as it approaches the viewport center (data-lit="fade").
      The engine places the meeting rooms in the layout's left column — the
      statement deliberately sits UNDER them, not over. */
  }
  <canvas id="dust" class="dust" aria-hidden="true"></canvas>
  <div class="container hero__frame">
    <div class="hero__copy" data-lit="fade">
      <p class="eyebrow">{floor.n}F · {floor.name} — terminal-native, open&nbsp;source</p>
      <h1 class="statement">
        Your agents<br />
        <span class="hl">work here</span><span class="cursor" aria-hidden="true"></span>
      </h1>
      <p class="statement-sub lead">
        Every Claude Code, Codex, or Cursor session walks in, sits down, and gets to work — in a
        pixel office that lives in your terminal.
      </p>
      <div class="hero__cta">
        <a class="btn btn-primary" href="#install">[ install <span aria-hidden="true">→</span> ]</a>
        <a class="hero__ghost" href={REPO} target="_blank" rel="noreferrer">star on github ↗</a>
      </div>
      <p class="hero__avail">macOS · Linux · Windows · crates.io · MIT&nbsp;licensed</p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-block: 0 clamp(3.5rem, 8vh, 6rem);
  }
  .dust {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .hero__frame {
    position: relative;
    z-index: 1;
    width: 100%;
    /* one shared rail: hero, nav, and every section head align on --maxw */
    max-width: var(--maxw);
  }
  .hero__copy {
    max-width: 900px;
  }
  .hero__copy .statement .hl {
    /* the gradient headline treatment, kept */
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.4rem;
    margin-top: 1.8rem;
  }
  .hero__ghost {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--fg);
    text-decoration: none;
    text-shadow: var(--chrome-halo);
  }
  .hero__ghost:hover {
    color: var(--coral);
  }
  .hero__avail {
    margin-top: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
  }
  /* one orchestrated page-load entrance, staggered */
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .hero__copy > * {
    animation: rise 0.7s both;
  }
  .hero__copy .eyebrow {
    animation-delay: 0.05s;
  }
  .hero__copy h1 {
    animation-delay: 0.14s;
  }
  .hero__copy .lead {
    animation-delay: 0.26s;
  }
  .hero__copy .hero__cta {
    animation-delay: 0.38s;
  }
  .hero__copy .hero__avail {
    animation-delay: 0.48s;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__copy > * {
      animation: none;
    }
  }
</style>

<script is:inline>
  // Pixel-dust: warm motes drifting up through the hero (echoes the office's dust).
  (function () {
    const c = document.getElementById('dust');
    if (!c) return;
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const ctx = c.getContext('2d');
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0,
      H = 0,
      motes = [];
    const COLORS = ['#d97757', '#e6a356', '#c9b08a', '#f0e4cf'];
    function spawn(anywhere) {
      return {
        x: Math.random() * W,
        y: anywhere ? Math.random() * H : H + 4,
        s: 2 + Math.floor(Math.random() * 2),
        vy: -(0.12 + Math.random() * 0.3),
        vx: (Math.random() - 0.5) * 0.2,
        a: 0.15 + Math.random() * 0.5,
        tw: Math.random() * 6.28,
        tws: 0.01 + Math.random() * 0.03,
        col: COLORS[Math.floor(Math.random() * COLORS.length)],
      };
    }
    function resize() {
      const r = c.getBoundingClientRect();
      W = r.width;
      H = r.height;
      c.width = Math.round(W * dpr);
      c.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const n = Math.max(18, Math.round((W * H) / 13000));
      motes = [];
      for (let i = 0; i < n; i++) motes.push(spawn(true));
    }
    let raf = 0,
      on = false,
      visible = false,
      userPaused = false;
    function frame() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < motes.length; i++) {
        const m = motes[i];
        m.x += m.vx;
        m.y += m.vy;
        m.tw += m.tws;
        if (m.y < -4) {
          motes[i] = spawn(false);
          continue;
        }
        ctx.globalAlpha = m.a * (0.55 + 0.45 * Math.sin(m.tw));
        ctx.fillStyle = m.col;
        ctx.fillRect(Math.round(m.x), Math.round(m.y), m.s, m.s);
      }
      ctx.globalAlpha = 1;
      raf = requestAnimationFrame(frame);
    }
    function start() {
      if (on || mq.matches || !visible || userPaused) return;
      on = true;
      raf = requestAnimationFrame(frame);
    }
    function stop() {
      on = false;
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    }
    resize();
    let rraf = 0;
    window.addEventListener('resize', function () {
      if (rraf) return; // coalesce a burst of resize events into one rAF
      rraf = requestAnimationFrame(function () {
        rraf = 0;
        resize();
      });
    });
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(
        function (es) {
          es.forEach(function (e) {
            visible = e.isIntersecting;
            if (visible) start();
            else stop();
          });
        },
        { threshold: 0 }
      ).observe(c);
    } else {
      visible = true;
      start();
    }
    // CSS @media can't gate a canvas rAF — respond to OS reduce-motion live
    if (mq.addEventListener)
      mq.addEventListener('change', function () {
        if (mq.matches) stop();
        else start();
      });
    // the office pause switch governs page motion (WCAG 2.2.2) — hold the dust too
    document.addEventListener('pix:paused', function (e) {
      userPaused = !!(e.detail && e.detail.paused);
      if (userPaused) stop();
      else start();
    });
  })();
</script>
