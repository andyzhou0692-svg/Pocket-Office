---
import { REPO, floorById, floorName } from '../consts';
import sources from '../sources.json';

const floor = floorById('lobby');
// Same manifest + supported-filter SupportedTools.astro renders its tools
// table from — a bridge e2e (smoke.spec.ts) pins this chip count to that
// table's row count, so the two consumers can't silently diverge.
const badges = sources.filter((s) => s.status === 'supported');
---

<section id={floor.id} class="hero" data-floor={floor.fl} data-floor-label={floor.label}>
  {
    /* The title card: the live office (page-wide backdrop) is fully lit at
      scroll-0; the statement sits bottom-left, film-title style, and pulls
      the dimmer in as it approaches the viewport center (data-lit="fade").
      The engine places the meeting rooms in the layout's left column — the
      statement deliberately sits UNDER them, not over. */
  }
  <canvas id="dust" class="dust" aria-hidden="true"></canvas>
  <div class="container hero__frame">
    <div class="hero__copy" data-lit="fade" data-lit-max="0.74">
      <p class="eyebrow">{floor.fl} · {floorName(floor)} — terminal-native, open&nbsp;source</p>
      <h1 class="statement">
        Your agents<br />
        <span class="hl">work here</span><span class="cursor" aria-hidden="true"></span>
      </h1>
      <p class="statement-sub lead">
        Every session walks in, sits down, and gets to work — in a pixel office that lives in your
        terminal.
      </p>
      <ul class="hero__badges" aria-label={`Works with ${badges.length} coding CLIs`}>
        {
          badges.map((s) => (
            <li class="hero__badge" style={`--badge:${s.badge_color}`}>
              <span class="hero__badge-code">{s.badge.replace('·', '')}</span> {s.name}
            </li>
          ))
        }
      </ul>
      <div class="hero__cta">
        <a class="btn btn-primary" href="#install">[ install <span aria-hidden="true">→</span> ]</a>
        <a class="hero__ghost" href="#showcase-vibing"
          ><span aria-hidden="true">▸</span> play with it live</a
        >
        <a class="hero__ghost" href={REPO} target="_blank" rel="noreferrer">star on github ↗</a>
      </div>
      <p class="hero__avail">macOS · Linux · source build · MIT&nbsp;licensed</p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh; /* fallback for Safari < 15.4, which drops the svh line */
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    /* Top: reserve the floating nav's row (--nav-h + a breath) — the copy is
       bottom-anchored, so whenever it outgrows the viewport (narrow phones,
       iOS text inflation) its TOP is what gives way, and with no reservation
       the eyebrow slid under the absolute nav's logo (mobile overlap bug).
       Desktop is unaffected: the copy is short, so flex-end keeps it at the
       bottom and the padding is dead space it never reaches. */
    padding-block: calc(var(--nav-h) + 0.75rem) clamp(3.5rem, 8vh, 6rem);
  }
  .dust {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .hero__frame {
    position: relative;
    z-index: 1;
    width: 100%;
    /* one shared rail: hero, nav, and every section head align on --maxw */
    max-width: var(--maxw);
  }
  .hero__copy {
    max-width: 900px;
  }
  .hero__copy .statement .hl {
    /* the gradient headline treatment, kept */
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.4rem;
    margin-top: 1.8rem;
  }
  .hero__ghost {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--fg);
    text-decoration: none;
    text-shadow: var(--chrome-halo);
  }
  .hero__ghost:hover {
    color: var(--coral);
  }
  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.15rem 0 0;
    padding: 0;
    list-style: none;
  }
  .hero__badge {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    padding: 0.32rem 0.6rem;
    /* DAY default: the light --surface family — a hairline-bordered chip,
       not the dark hardware panel (the dark chip read too heavy on the light
       day office, user-caught). NIGHT below switches to the --screen /
       --chip-line hardware family instead (the mock's look, matching the
       app's own dark Sources panel). */
    background: var(--surface);
    border: 1px solid var(--border-strong);
    color: var(--fg);
  }
  .hero__badge-code {
    font-weight: 700;
    /* the app's real per-CLI hue (sources.json badge_color, pinned to
       theme::NORMAL.source by crates/pixtuoid-scene/tests/site_badge_colors.rs),
       darkened toward black so it clears WCAG AA (4.5:1) on the light day
       chip — measured worst case (OpenClaw #ffaa30) 5.37:1 at 45% black; the
       e2e badge-hue sweep (smoke.spec.ts) pins every hue in both themes. */
    color: color-mix(in srgb, var(--badge) 55%, black);
  }
  :root[data-theme='night'] .hero__badge,
  :root[data-theme='dracula'] .hero__badge {
    /* dracula's --bg is dark too (same direction as night — see
       --office-ink's dracula arm in global.css); it piggybacks on night's
       already-measured formula rather than a third dedicated sweep. */
    background: var(--screen);
    border-color: var(--chip-line);
    color: var(--chip-ink);
  }
  :root[data-theme='night'] .hero__badge-code,
  :root[data-theme='dracula'] .hero__badge-code {
    /* lightened toward white so the hue clears 4.5:1 on the dark --screen
       chip — measured worst case (DeepSeek-Reasonix #9c3cc0) 5.09:1 at 20%
       white. */
    color: color-mix(in srgb, var(--badge) 80%, white);
  }
  .hero__avail {
    margin-top: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    /* bare over the live office (no plate) — --fg-muted measured short of
       WCAG AA at the office's real brightness extremes; see --office-ink's
       doc comment in global.css. */
    color: var(--office-ink);
  }
  /* one orchestrated page-load entrance, staggered */
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .hero__copy > * {
    animation: rise 0.7s both;
  }
  .hero__copy .eyebrow {
    animation-delay: 0.05s;
    /* bare over the live office (no plate) — the shared .eyebrow color
       (--coral-deep/--coral) measured short of WCAG AA at the office's real
       brightness extremes; --office-ink-accent keeps the coral accent (unlike
       --office-ink) while clearing it. See global.css's doc comment. */
    color: var(--office-ink-accent);
  }
  .hero__copy h1 {
    animation-delay: 0.14s;
  }
  .hero__copy .lead {
    animation-delay: 0.26s;
    /* bare over the live office (no plate) — see --office-ink's doc comment
       in global.css; this OVERRIDES the shared .lead's --fg-muted, scoped to
       the hero only (every other section's .lead sits over the deeper
       shared 0.86 dimmer cap, not this hero's 0.74, and stays --fg-muted). */
    color: var(--office-ink);
  }
  .hero__copy .hero__badges {
    animation-delay: 0.32s;
  }
  .hero__copy .hero__cta {
    animation-delay: 0.4s;
  }
  .hero__copy .hero__avail {
    animation-delay: 0.5s;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__copy > * {
      animation: none;
    }
  }
</style>

<script is:inline>
  // Pixel-dust: warm motes drifting up through the hero (echoes the office's dust).
  (function () {
    const c = document.getElementById('dust');
    if (!c) return;
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const ctx = c.getContext('2d');
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0,
      H = 0,
      motes = [];
    const COLORS = ['#d97757', '#e6a356', '#c9b08a', '#f0e4cf'];
    function spawn(anywhere) {
      return {
        x: Math.random() * W,
        y: anywhere ? Math.random() * H : H + 4,
        s: 2 + Math.floor(Math.random() * 2),
        vy: -(0.12 + Math.random() * 0.3),
        vx: (Math.random() - 0.5) * 0.2,
        a: 0.15 + Math.random() * 0.5,
        tw: Math.random() * 6.28,
        tws: 0.01 + Math.random() * 0.03,
        col: COLORS[Math.floor(Math.random() * COLORS.length)],
      };
    }
    function resize() {
      const r = c.getBoundingClientRect();
      W = r.width;
      H = r.height;
      c.width = Math.round(W * dpr);
      c.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const n = Math.max(18, Math.round((W * H) / 13000));
      motes = [];
      for (let i = 0; i < n; i++) motes.push(spawn(true));
    }
    let raf = 0,
      on = false,
      visible = false,
      userPaused = false;
    function frame() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < motes.length; i++) {
        const m = motes[i];
        m.x += m.vx;
        m.y += m.vy;
        m.tw += m.tws;
        if (m.y < -4) {
          motes[i] = spawn(false);
          continue;
        }
        ctx.globalAlpha = m.a * (0.55 + 0.45 * Math.sin(m.tw));
        ctx.fillStyle = m.col;
        ctx.fillRect(Math.round(m.x), Math.round(m.y), m.s, m.s);
      }
      ctx.globalAlpha = 1;
      raf = requestAnimationFrame(frame);
    }
    function start() {
      if (on || mq.matches || !visible || userPaused) return;
      on = true;
      raf = requestAnimationFrame(frame);
    }
    function stop() {
      on = false;
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    }
    resize();
    let rraf = 0;
    window.addEventListener('resize', function () {
      if (rraf) return; // coalesce a burst of resize events into one rAF
      rraf = requestAnimationFrame(function () {
        rraf = 0;
        resize();
      });
    });
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(
        function (es) {
          es.forEach(function (e) {
            visible = e.isIntersecting;
            if (visible) start();
            else stop();
          });
        },
        { threshold: 0 }
      ).observe(c);
    } else {
      visible = true;
      start();
    }
    // CSS @media can't gate a canvas rAF — respond to OS reduce-motion live
    if (mq.addEventListener)
      mq.addEventListener('change', function () {
        if (mq.matches) stop();
        else start();
      });
    // the office pause switch governs page motion (WCAG 2.2.2) — hold the dust too
    document.addEventListener('pix:paused', function (e) {
      userPaused = !!(e.detail && e.detail.paused);
      if (userPaused) stop();
      else start();
    });
  })();
</script>
