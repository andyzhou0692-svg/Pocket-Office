---
import { WEATHERS, asset } from '../consts';
// Storm is the most striking opener; fall back to the first if it's ever removed.
const def = WEATHERS.find((w) => w.id === 'storm') ?? WEATHERS[0];
---

<section id="weather" class="weather">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{WEATHERS.length} weather states · on your real clock</p>
      <h2>Rain or shine, out the window.</h2>
      <p class="lead">
        The skyline tracks your local time and weather slot — rain and snow streak the glass, fog
        swallows the city, and a storm flickers lightning off the walls. It rolls over on its own
        every few minutes.
      </p>
    </div>

    <div class="weather__stage reveal" id="weather-stage">
      <figure class="terminal weather__preview crt">
        <div class="terminal__bar">
          <span class="terminal__dot terminal__dot--r"></span>
          <span class="terminal__dot terminal__dot--y"></span>
          <span class="terminal__dot terminal__dot--g"></span>
          <span class="terminal__title" id="weather-title">{def.name} · {def.blurb}</span>
        </div>
        <img
          id="weather-img"
          class="terminal__screen px"
          src={asset(`demos/weather_${def.id}.png`)}
          alt={`pixtuoid office under ${def.name.toLowerCase()} weather`}
          width="1600"
          height="1440"
        />
        <span class="terminal__scan" aria-hidden="true"></span>
      </figure>

      <div class="weather__chips" role="group" aria-label="Weather">
        {
          WEATHERS.map((w) => (
            <button
              class:list={['weather__chip', { 'is-active': w.id === def.id }]}
              aria-pressed={w.id === def.id ? 'true' : 'false'}
              data-id={w.id}
              data-src={asset(`demos/weather_${w.id}.png`)}
              data-name={w.name}
              data-blurb={w.blurb}
            >
              {w.name}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const stage = document.getElementById('weather-stage');
    const img = document.getElementById('weather-img');
    const title = document.getElementById('weather-title');
    const chips = document.querySelectorAll('.weather__chip');
    if (!stage || !img) return;
    function pick(chip) {
      img.src = chip.dataset.src;
      img.alt = 'pixtuoid office under ' + chip.dataset.name.toLowerCase() + ' weather';
      if (title) title.textContent = chip.dataset.name + ' · ' + chip.dataset.blurb;
      const preview = stage.querySelector('.weather__preview');
      if (preview) {
        preview.classList.remove('retint-pulse');
        void preview.offsetWidth;
        preview.classList.add('retint-pulse');
      }
      chips.forEach(function (c) {
        const on = c === chip;
        c.classList.toggle('is-active', on);
        c.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    }
    const prefetched = {};
    function prefetch(src) {
      if (src && !prefetched[src]) {
        prefetched[src] = new Image();
        prefetched[src].src = src;
      }
    }
    chips.forEach(function (c) {
      // warm the weather PNG on hover so the click swaps an already-cached image
      c.addEventListener('pointerenter', function () {
        prefetch(c.dataset.src);
      });
      c.addEventListener('click', function () {
        pick(c);
      });
    });
  })();
</script>

<style>
  .weather {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }
  .weather__stage {
    display: grid;
    gap: 1.4rem;
  }
  .weather__preview {
    box-shadow: var(--shadow-lg);
  }
  .weather__preview .terminal__screen {
    width: 100%;
    height: auto;
  }
  .weather__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .weather__chip {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.84rem;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    cursor: pointer;
    color: var(--fg-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.15s ease;
  }
  .weather__chip:hover {
    color: var(--fg);
    transform: translateY(-1px);
  }
  .weather__chip.is-active {
    color: var(--fg);
    border-color: color-mix(in srgb, var(--coral) 60%, var(--border-strong));
    background: color-mix(in srgb, var(--coral) 15%, var(--surface));
  }
</style>
