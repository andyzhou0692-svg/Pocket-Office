---
import {
  asset,
  type EnrichedShowcaseChannel,
  type EnrichedVariantGroup,
  type ShowcaseVariant,
} from '../consts';

const { channel: c, active } = Astro.props as {
  channel: EnrichedShowcaseChannel;
  active: boolean;
};
const isClip = c.kind === 'clip';
const isLive = c.kind === 'live';
// showcase.json's diegetic caption is the primary copy; a channel that would
// just restate its joined feature's desc (currently only "pets") omits
// caption and falls back here — one description, not a same-screen repeat
// (site/CLAUDE.md's Single-sourced-content section).
const description = c.caption ?? c.featureDesc;
const defVariant: ShowcaseVariant | null = c.variants.length
  ? (c.variants.find((v: ShowcaseVariant) => v.featured) ?? c.variants[0])
  : null;
const title = `pixtuoid — CH ${c.ch} ${c.label}` + (defVariant ? ` · ${defVariant.name}` : '');
const imgAlt = defVariant
  ? `pixtuoid office — ${defVariant.name} (${c.label.toLowerCase()})`
  : isLive
    ? `pixtuoid office — live (${c.label.toLowerCase()})`
    : '';

// A live channel's default chip per group — the vibe a visitor should land
// on (weather → `clear`, theme → `normal`) — falling back to the group's
// first variant if that id isn't present.
const DEFAULT_VARIANT_ID: Record<string, string> = { weather: 'clear', theme: 'normal' };
function defaultVariant(g: EnrichedVariantGroup): ShowcaseVariant | undefined {
  const wanted = DEFAULT_VARIANT_ID[g.key];
  const preferred = wanted ? g.variants.find((v) => v.id === wanted) : undefined;
  return preferred ?? g.variants[0];
}
---

<figure
  class="terminal stage crt"
  data-stage={c.id}
  data-retint={c.retint ? 'true' : undefined}
  hidden={!active}
  style={defVariant?.accent ? `--accent:${defVariant.accent}` : undefined}
>
  <div class="terminal__bar">
    <span class="terminal__dot terminal__dot--r"></span>
    <span class="terminal__dot terminal__dot--y"></span>
    <span class="terminal__dot terminal__dot--g"></span>
    <span class="terminal__title" data-stage-title>{title}</span>
  </div>
  {
    /* No `autoplay`: it overrides preload="metadata" and eagerly downloads the
      whole (below-the-fold) webm at page load. The IntersectionObserver play
      policy in Showcase.astro already play()s the picked+visible clip, so
      autoplay bought nothing for JS visitors while costing ~294KB. Trade-off: a
      no-JS visitor sees the poster instead of a playing clip (acceptable — the
      dial/OSD are JS-only anyway). Hidden demos defer their poster too
      (data-poster → hydrate()), so only the active poster is fetched at load. */
  }
  {
    isClip ? (
      <video
        class="terminal__screen px"
        width={c.w}
        height={c.h}
        muted
        loop
        playsinline
        preload={active ? 'metadata' : 'none'}
        poster={active ? asset(`demos/${c.asset}-poster.png`) : undefined}
        data-poster={active ? undefined : asset(`demos/${c.asset}-poster.png`)}
        data-mp4={active ? undefined : asset(`demos/${c.asset}.mp4`)}
        data-webm={active ? undefined : asset(`demos/${c.asset}.webm`)}
        aria-label={`pixtuoid demo: ${description}`}
      >
        {active && <source src={asset(`demos/${c.asset}.webm`)} type="video/webm" />}
        {active && <source src={asset(`demos/${c.asset}.mp4`)} type="video/mp4" />}
      </video>
    ) : isLive ? (
      <div class="vibing__screen">
        <img
          class="terminal__screen px vibing__poster"
          width={c.w ?? 320}
          height={c.h ?? 180}
          src={active && c.poster ? asset(`demos/${c.poster}`) : undefined}
          data-src={active || !c.poster ? undefined : asset(`demos/${c.poster}`)}
          data-vibing-poster
          alt={imgAlt}
          loading="lazy"
        />
        <canvas
          class="terminal__screen px"
          width={c.w ?? 320}
          height={c.h ?? 180}
          data-vibing-canvas
        />
      </div>
    ) : (
      <img
        class="terminal__screen px"
        width={c.w ?? 1600}
        height={c.h ?? 1440}
        src={active ? asset(`demos/${defVariant!.src}`) : undefined}
        data-src={active ? undefined : asset(`demos/${defVariant!.src}`)}
        alt={imgAlt}
        loading="lazy"
      />
    )
  }
  <span class="terminal__scan" aria-hidden="true"></span>
  {
    isLive ? (
      <>
        {c.timeSlider && (
          <div class="vibing__time" data-phase="day">
            <div class="vibing__sky">
              <input
                type="range"
                min="0"
                max="24"
                step="0.5"
                value="18"
                data-vibing-time
                aria-label="time of day"
              />
              <div class="vibing__ticks" aria-hidden="true">
                <span>00</span>
                <span>06</span>
                <span>12</span>
                <span>18</span>
                <span>24</span>
              </div>
            </div>
            <span class="vibing__clock" data-vibing-time-label>
              18:00
            </span>
          </div>
        )}
        {c.groups.map((g: EnrichedVariantGroup) => {
          const def = defaultVariant(g);
          const dataKey = `data-${g.key}`;
          return (
            <div
              class="stage__osd"
              data-group={g.key}
              data-retint={g.retint ? 'true' : undefined}
              role="group"
              aria-label={g.label}
            >
              {g.variants.map((v: ShowcaseVariant) => (
                <button
                  class:list={['osd__chip', { 'is-active': v.id === def?.id }]}
                  aria-pressed={v.id === def?.id ? 'true' : 'false'}
                  {...{ [dataKey]: v.id }}
                  data-accent={v.accent}
                  data-accent2={v.accent2}
                  style={v.accent ? `--chip:${v.accent}` : undefined}
                >
                  {v.accent && <span class="osd__swatch" />}
                  {v.name}
                </button>
              ))}
            </div>
          );
        })}
      </>
    ) : (
      c.variants.length > 0 && (
        <div class="stage__osd" role="group" aria-label={c.label.toLowerCase()}>
          {c.variants.map((v: ShowcaseVariant) => (
            <button
              class:list={['osd__chip', { 'is-active': v.id === defVariant!.id }]}
              aria-pressed={v.id === defVariant!.id ? 'true' : 'false'}
              data-src={asset(`demos/${v.src}`)}
              data-title={`pixtuoid — CH ${c.ch} ${c.label} · ${v.name}`}
              data-alt={`pixtuoid office — ${v.name} (${c.label.toLowerCase()})`}
              data-accent={v.accent}
              data-accent2={v.accent2}
              style={v.accent ? `--chip:${v.accent}` : undefined}
            >
              {v.accent && <span class="osd__swatch" />}
              {v.name}
            </button>
          ))}
        </div>
      )
    )
  }
  <figcaption class="stage__caption">{description}</figcaption>
</figure>

<style>
  .stage {
    --accent: var(--coral);
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border-strong));
    box-shadow:
      var(--shadow-lg),
      0 0 0 1px color-mix(in srgb, var(--accent) 22%, transparent),
      0 30px 80px color-mix(in srgb, var(--accent) 22%, transparent);
    transition:
      box-shadow 0.45s ease,
      border-color 0.45s ease;
  }
  .stage .terminal__screen {
    width: 100%;
    height: auto;
  }
  /* poster is the in-flow base layer (sizes the wrapper via its intrinsic
     w/h attrs); the canvas paints over it once the controller (Task 8)
     boots — no z-index needed, painting order already puts the absolutely
     positioned canvas above the static poster. */
  .vibing__screen {
    position: relative;
  }
  .vibing__screen .vibing__poster {
    position: relative;
  }
  .vibing__screen [data-vibing-canvas] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    /* override .terminal__screen's opaque `background: var(--screen)` — an
       untouched canvas has no drawn pixels, so an opaque bg would black out
       the poster underneath until the controller (Task 8) starts painting */
    background: transparent;
  }
  /* the VIBING time control is a "sky scrubber": the track IS a full day of
     sky (00→24h), and the thumb is a glowing sun that becomes a cool moon after
     dusk. Phase (day/night) is set on the wrapper by Showcase.astro's slider
     handler and swaps its four --thumb-… and --clock-glow vars below — the
     webkit AND moz pseudo-elements both read those vars, so one phase flip restyles
     the thumb + clock without touching each pseudo. (webkit/moz pseudo rules
     MUST stay split — a browser drops a whole rule that lists a pseudo it
     doesn't know.) */
  .vibing__time {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.9rem 0.9rem 0.2rem;
    /* track/thumb geometry named once — the -webkit- thumb offset derives from
       these, so a size tweak can't drift across the 3 track + 2 thumb sites. */
    --track-h: 16px;
    --thumb-d: 24px;
    /* a dark hairline so the thumb clears WCAG 1.4.11 (≥3:1 non-text) even over
       the bright noon band, where the warm sun fill alone is ~1.4:1; pairs with
       the light --thumb-ring border for a two-tone edge that reads on any sky. */
    --thumb-edge: 0 0 0 1px rgba(10, 14, 36, 0.6);
    --sky: linear-gradient(
      90deg,
      #0a0e24 0%,
      #172046 18%,
      #d9744f 27%,
      #9cc3e6 44%,
      #bfe0f2 50%,
      #9cc3e6 58%,
      #e0844a 74%,
      #6b3f66 82%,
      #141a38 90%,
      #0a0e24 100%
    );
    --thumb-fill: radial-gradient(
      circle at 38% 34%,
      #fff7dc 0%,
      #ffd873 42%,
      #f6a63f 78%,
      #e8863a 100%
    );
    --thumb-glow: 0 0 9px 2px rgba(255, 200, 90, 0.85), 0 0 20px 6px rgba(240, 150, 60, 0.45);
    --thumb-ring: rgba(255, 240, 200, 0.7);
    --clock-glow: 0 0 10px rgba(246, 166, 63, 0.55);
  }
  .vibing__time[data-phase='night'] {
    --thumb-fill: radial-gradient(circle at 40% 36%, #f4f7ff 0%, #d3ddf6 48%, #97a2c8 100%);
    --thumb-glow: 0 0 8px 2px rgba(200, 212, 248, 0.7), 0 0 18px 5px rgba(120, 132, 180, 0.4);
    --thumb-ring: rgba(230, 236, 255, 0.7);
    --clock-glow: 0 0 10px rgba(150, 162, 200, 0.6);
  }
  .vibing__sky {
    flex: 1;
    min-width: 0;
  }
  .vibing__time input[type='range'] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: var(--track-h);
    background: transparent;
    cursor: pointer;
  }
  .vibing__time input[type='range']::-webkit-slider-runnable-track {
    height: var(--track-h);
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.45);
    background: var(--sky);
  }
  .vibing__time input[type='range']::-moz-range-track {
    height: var(--track-h);
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.45);
    background: var(--sky);
  }
  .vibing__time input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: var(--thumb-d);
    height: var(--thumb-d);
    margin-top: calc((var(--track-h) - var(--thumb-d)) / 2); /* center thumb on track */
    border-radius: 50%;
    border: 1px solid var(--thumb-ring);
    background: var(--thumb-fill);
    box-shadow: var(--thumb-edge), var(--thumb-glow);
    transition: box-shadow 0.2s ease;
  }
  .vibing__time input[type='range']::-moz-range-thumb {
    width: var(--thumb-d);
    height: var(--thumb-d);
    border-radius: 50%;
    border: 1px solid var(--thumb-ring);
    background: var(--thumb-fill);
    box-shadow: var(--thumb-edge), var(--thumb-glow);
  }
  /* Firefox can paint a default "progress" fill left of the thumb; with
     appearance:none it usually doesn't, but keep it transparent so it can never
     overlay the sky gradient's morning half. */
  .vibing__time input[type='range']::-moz-range-progress {
    background: transparent;
  }
  .vibing__time input[type='range']:focus-visible::-webkit-slider-thumb {
    box-shadow:
      0 0 0 3px var(--bg),
      0 0 0 5px var(--accent),
      var(--thumb-glow);
  }
  .vibing__time input[type='range']:focus-visible::-moz-range-thumb {
    box-shadow:
      0 0 0 3px var(--bg),
      0 0 0 5px var(--accent);
  }
  .vibing__ticks {
    display: flex;
    justify-content: space-between;
    margin-top: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    opacity: 0.7;
  }
  .vibing__clock {
    min-width: 4.1em;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    font-variant-numeric: tabular-nums;
    color: var(--fg);
    text-shadow: var(--clock-glow);
  }
  .stage__osd {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0.8rem 0.9rem 0.2rem;
  }
  .osd__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.84rem;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    cursor: pointer;
    color: var(--fg-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.15s ease;
  }
  .osd__chip:hover {
    color: var(--fg);
    transform: translateY(-1px);
  }
  .osd__chip.is-active {
    color: var(--fg);
    border-color: color-mix(in srgb, var(--chip, var(--coral)) 60%, var(--border-strong));
    background: color-mix(in srgb, var(--chip, var(--coral)) 15%, var(--surface));
  }
  .osd__swatch {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    background: var(--chip);
    /* a perceivable edge so the swatch reads even when its fill is below the
       WCAG 1.4.11 3:1 non-text contrast against the chip surface */
    border: 1px solid var(--border-strong);
    image-rendering: pixelated;
  }
  .stage__caption {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    color: var(--fg-muted);
    padding: 0.7rem 0.9rem 0.9rem;
  }
</style>
