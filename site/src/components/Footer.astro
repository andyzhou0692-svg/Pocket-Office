---
import { REPO, CRATES, SPONSOR, asset } from '../consts';
---

<footer class="footer">
  <div class="container footer__line">
    <a class="footer__logo" href="#top">
      <img
        class="footer__mark"
        src={asset('char-mark.png')}
        alt=""
        aria-hidden="true"
        width="17"
        height="24"
      />
      pixtuoid
    </a>
    <span class="footer__sep">·</span>
    <span>MIT</span>
    <span class="footer__sep">·</span>
    <span>built in Rust 🦀</span>
    <span class="footer__sep">·</span>
    <a href={REPO} target="_blank" rel="noreferrer">GitHub</a>
    <span class="footer__sep">·</span>
    <a href={CRATES} target="_blank" rel="noreferrer">crates.io</a>
    <span class="footer__sep">·</span>
    <a href={`${REPO}/releases`} target="_blank" rel="noreferrer">Releases</a>
    <span class="footer__sep">·</span>
    <a class="footer__coffee" href={SPONSOR} target="_blank" rel="noreferrer">☕ Coffee</a>
    <span class="footer__sep">·</span>
    <span>made with Claude Code</span>
    {/* visible only while the clock (not the visitor, not the OS) holds night */}
    <span class="footer__clock">after hours</span>
  </div>
</footer>

<style>
  .footer {
    margin-top: clamp(2rem, 6vw, 5rem);
    padding-block: 1.4rem;
  }
  /* The line floats over the released dimmer (office fully lit) at page end,
     so it rides the same --screen chip as every other over-office caption —
     theme-independent inks, never --fg-muted (invisible on the day office). */
  .footer__line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    width: fit-content;
    padding: 0.5rem 0.8rem;
    background: var(--chip-bg);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--chip-ink);
  }
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-synthesis: none;
    font-size: 1.1rem;
    color: var(--chip-bright);
    text-decoration: none;
  }
  .footer__mark {
    height: 20px;
    width: auto;
    image-rendering: pixelated;
  }
  .footer__sep {
    color: var(--chip-dim);
  }
  .footer__line a {
    color: var(--chip-ink);
    text-decoration: none;
  }
  .footer__line a:hover {
    color: #fff;
  }
  .footer__coffee {
    color: var(--coral) !important;
  }
  /* shown only when the local clock holds night — toggled by the Base script */
  .footer__clock {
    display: none;
    color: var(--amber);
  }
  :global([data-clock-night='1']) .footer__clock {
    display: inline;
  }
</style>
