---
import { REPO, CRATES, SPONSOR, asset } from '../consts';
---

<footer class="footer">
  <div class="container footer__line">
    <a class="footer__logo" href="#top">
      <img
        class="footer__mark js-brand-mark"
        src={asset('favicon-32.png')}
        alt=""
        aria-hidden="true"
        width="32"
        height="32"
      />
      pixtuoid
    </a>
    <span class="footer__grp"><span class="footer__sep">·</span> MIT</span>
    <span class="footer__grp"><span class="footer__sep">·</span> built in Rust 🦀</span>
    <span class="footer__grp">
      <span class="footer__sep">·</span>
      <a href={REPO} target="_blank" rel="noreferrer">GitHub</a>
    </span>
    <span class="footer__grp">
      <span class="footer__sep">·</span>
      <a href={CRATES} target="_blank" rel="noreferrer">crates.io</a>
    </span>
    <span class="footer__grp">
      <span class="footer__sep">·</span>
      <a href={`${REPO}/releases`} target="_blank" rel="noreferrer">Releases</a>
    </span>
    <span class="footer__grp">
      <span class="footer__sep">·</span>
      <a class="footer__coffee" href={SPONSOR} target="_blank" rel="noreferrer">☕ Coffee</a>
    </span>
    <span class="footer__grp"><span class="footer__sep">·</span> made with Claude Code</span>
    {/* visible only while the clock (not the visitor, not the OS) holds night */}
    <span class="footer__clock">after hours</span>
  </div>
</footer>

<style>
  .footer {
    /* compression (§4, scroll-budget pin): same tightened rhythm as the
       shared `section` rule, same reasoning (global.css). */
    margin-top: clamp(1.5rem, 5vw, 3rem);
    padding-block: 1.4rem;
  }
  /* The line floats over the released dimmer (office fully lit) at page end,
     so it rides the same --screen chip as every other over-office caption —
     theme-independent inks, never --fg-muted (invisible on the day office). */
  .footer__line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    width: fit-content;
    padding: 0.5rem 0.8rem;
    background: var(--chip-bg);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--chip-ink);
  }
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-synthesis: none;
    font-size: 1.1rem;
    color: var(--chip-bright);
    text-decoration: none;
  }
  .footer__mark {
    /* exactly half the favicon's native 32px (a clean 2:1), so the pixel bust
       stays device-exact on retina — the common case — where 16 CSS px = 32
       device px. See .nav__mark for the 1:1 rationale. */
    height: 16px;
    width: 16px;
    image-rendering: pixelated;
  }
  .footer__sep {
    color: var(--chip-dim);
  }
  /* Groups a "·" with the item it introduces into ONE flex item, so
     flex-wrap can only break BETWEEN groups — never leave a separator
     stranded alone at the start of a wrapped line (#U8: a bare .footer__sep
     span had no affinity for its neighbor). white-space:nowrap is a second
     backstop against an internal break inside the (short) group itself. */
  .footer__grp {
    white-space: nowrap;
  }
  /* The grouping above stops a dot from being stranded ALONE mid-row, but a
     GROUP that itself wraps to start a new line still leads that line with
     its own dot (#wb-3: "· built in Rust" opening line 2) — each "·"
     introduces its FOLLOWING item, so it can only ever land at a line's
     leading edge, never trailing. Below the width where the row visibly
     wraps (.footer__line's own flex-wrap, measured ≤960px), drop the dots
     and let the row's gap carry the separation instead. */
  @media (max-width: 960px) {
    .footer__sep {
      display: none;
    }
  }
  .footer__line a {
    color: var(--chip-ink);
    text-decoration: none;
  }
  .footer__line a:hover {
    color: #fff;
  }
  .footer__coffee {
    color: var(--coral) !important;
  }
  /* shown only when the local clock holds night — toggled by the Base script */
  .footer__clock {
    display: none;
    color: var(--amber);
  }
  :global([data-clock-night='1']) .footer__clock {
    display: inline;
  }
</style>
