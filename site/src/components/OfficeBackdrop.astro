---
import { asset, DIM_RESTING } from '../consts';
---

{
  /* THE BUILDING — the real pixtuoid engine (wasm) running fixed behind the
     whole page: ONE continuous office (the hero's Dense variant — two
     meeting rooms), one timeline that never resets while you scroll.
     Content floats over it as glass bands. Cover-first: on the wasm-boot path
     the canvas covers the baked poster with its OWN bg tone (background:
     var(--bg), which tracks the wall clock) from the first paint, then
     FLOOR-ROLLS up out of that tone into the LIVE frame once the boot splash
     clears — never a cross-dissolve of the wrong-time still, so the day/night
     flip is gone by construction (see the reveal in the script). The poster
     (demos/hero-wide.png) is a REAL wasm-hero frame at the 320x180 buffer a
     16:9 canvas computes (#425) and stays the instant FALLBACK layer.
     Reduced-motion / no-JS / no-wasm / fetch-failure all simply stay on
     the still. */
}
<div class="backdrop" aria-hidden="true">
  <img
    class="backdrop__poster px"
    src={asset('demos/hero-wide.png')}
    alt=""
    width="320"
    height="180"
    decoding="async"
    fetchpriority="high"
  />
  <canvas id="office-live" class="backdrop__live px"></canvas>
</div>
{
  /* THE DIMMER — the design's signature. A fixed var(--bg) sheet whose
     opacity is written per-frame by the scroll controller below: 0 in
     observation gaps (the office fully bright IS the content), up to 0.86
     when a statement owns the viewport center. Compositor-only (a single
     style.opacity write), never pauses the canvas. */
}
{
  /* --dim-rest single-sources the resting opacity with consts DIM_RESTING (also
   the statusline's 'lights N%' readout) — a JS↔CSS value that can't share a
   literal, so it rides an inline custom property both #dimmer rules read. */
}
<div id="dimmer" aria-hidden="true" style={`--dim-rest:${DIM_RESTING}`}></div>
{
  /* THE PAUSE SWITCH (WCAG 2.2.2) — a real, keyboard-reachable <button> for the
     page's auto-motion. Shown whenever motion runs = NOT reduced-motion: it
     governs the wasm-INDEPENDENT ambient motion (statusline ticker, hero dust,
     showcase clips) via pix:paused, so it stays reachable even on the no-wasm /
     fetch-failure poster paths where the office canvas never goes live (#456).
     Only reduced-motion hides it (nothing auto-animates there). aria-pressed
     carries the state; the label stays constant (toggle-button convention).
     Icons are inline pixel SVGs on an 8×8 grid (crispEdges — no anti-aliased
     glyph fonts near the office's pixels). */
}
<button
  id="office-pause"
  class="office-ctl"
  hidden
  aria-pressed="false"
  aria-label="Pause the office animation"
>
  <svg class="office-ctl__pause" viewBox="0 0 8 8" shape-rendering="crispEdges" aria-hidden="true">
    <rect x="1" y="1" width="2" height="6"></rect>
    <rect x="5" y="1" width="2" height="6"></rect>
  </svg>
  <svg class="office-ctl__play" viewBox="0 0 8 8" shape-rendering="crispEdges" aria-hidden="true">
    <rect x="2" y="1" width="1" height="7"></rect>
    <rect x="3" y="2" width="1" height="5"></rect>
    <rect x="4" y="3" width="1" height="3"></rect>
    <rect x="5" y="4" width="1" height="1"></rect>
  </svg>
</button>

<style is:global>
  /* The fixed canvas sits at z:-1; the body's opaque background would hide
     it. The html root keeps --bg (no white flash); content paints its own
     glass. Scoped to pages that render this component. */
  body {
    background: transparent;
  }
  .backdrop {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: var(--bg);
    pointer-events: none;
  }
  .backdrop__poster,
  .backdrop__live {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* The canvas is BOTH the office AND — until it rolls in — the load-gap cover.
     Opacity is JS-driven (the reveal in the script). Default 0 so every NON-boot
     path (no-JS / no-wasm / fetch-fail / reduced-motion) shows the poster; the
     boot path raises it to 1 so the canvas's own bg tone (background: var(--bg),
     which tracks the wall clock — cream by day, dark by night) hides the baked
     poster until the LIVE office floor-rolls in. The roll paints with alpha, so
     its fade-in and floor-seams let this bg tone show through, occluding the
     poster. Net: the reveal never cross-dissolves a wrong-time still — the
     day/night flip is gone by construction. */
  .backdrop__live {
    opacity: 0;
    background: var(--bg);
  }
  /* reduced motion IS the still-poster design — never cover it (wins even before
     the script runs) */
  @media (prefers-reduced-motion: reduce) {
    .backdrop__live {
      opacity: 0 !important;
    }
  }
  #dimmer {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: var(--bg);
    opacity: var(--dim-rest); /* pre-JS / reduced-motion resting level (consts DIM_RESTING) */
    pointer-events: none;
  }
  /* Reduced motion is a complete parallel design: the office is the still
     poster, the dimmer holds a constant readable level, nothing scrolls-
     animates. (The controller also early-returns.) */
  @media (prefers-reduced-motion: reduce) {
    #dimmer {
      opacity: var(--dim-rest) !important;
    }
  }
  /* The pause switch: 8-bit hardware — square, hard edges, a 1px offset
     "casing" shadow, icons at an integer 3x of their 8×8 grid. Sits just
     above the statusline, out of the dimmer's reach (fixed chrome, like the
     statusline itself). Translucent at rest so it reads as part of the
     office; solid on hover/focus and while paused (a frozen office must
     announce why). */
  /* the class display beats [hidden]'s UA rule — restate it (same trap as
     the statusline's .sl__floors[hidden]) */
  :root {
    /* the button's own footprint, named so the ≤760px content-gutter rule
       below can reserve exactly this much (never a second copy to drift). */
    --office-ctl-edge: 10px;
    --office-ctl-w: 36px;
  }
  .office-ctl[hidden] {
    display: none;
  }
  .office-ctl {
    position: fixed;
    right: var(--office-ctl-edge);
    bottom: calc(2rem + env(safe-area-inset-bottom, 0px) + 10px);
    z-index: 50;
    width: var(--office-ctl-w);
    height: var(--office-ctl-w);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--screen);
    border: 2px solid var(--chip-line);
    border-radius: 0;
    box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.45);
    color: var(--chip-bright);
    cursor: pointer;
    opacity: 0.45;
    transition: opacity 0.15s ease;
  }
  /* Footer.astro's flex-wrap row sits directly above the statusline with no
     clearance, and its fit-content width degenerates to full-container width
     once it wraps (≤960px, measured) — its own bg plate then reaches this
     control's x-position, and at the true scroll-bottom its taller wrapped
     box vertically overlaps this control's fixed band too (both sit flush
     against the reserved statusline height by construction). The wrap count
     itself isn't fixed at 2 lines — it varies non-monotonically with viewport
     width (measured 3 lines in the 360-460px band), so a flat pixel offset
     either overlaps a taller wrap or overshoots a shorter one; --footer-h
     (below) tracks the footer's REAL rendered height instead. The var()
     fallback (74px = the old flat 84px minus this rule's own +10px gap)
     only ever shows pre-JS/no-JS, matching the prior static behavior until
     the ResizeObserver in the script below reports the real height. */
  @media (max-width: 960px) {
    .office-ctl {
      bottom: calc(2rem + env(safe-area-inset-bottom, 0px) + var(--footer-h, 74px) + 10px);
    }
  }
  /* The clearance above only ever kept the FOOTER's own copy clear of the
     button. But .office-ctl is position:fixed — its on-screen band is
     constant across the whole scroll, so every section's copy passes under
     it at some scroll offset, not just the footer's. At ≤760px .container
     nearly fills the viewport (no side margin wide enough to clear the
     button on its own), so widen just its END padding by the button's own
     footprint (--office-ctl-edge/-w above — never a second copy of those
     numbers). The two office-gap captions render OUTSIDE .container (direct
     <main> children, #wb-3), so they need the same reservation applied
     directly via a matching max-width. */
  @media (max-width: 760px) {
    .container {
      padding-inline-end: calc(
        var(--container-pad-x) + var(--office-ctl-edge) + var(--office-ctl-w) + 8px
      );
    }
    .gap-caption {
      max-width: calc(
        100% - var(--gap-caption-inset) - var(--office-ctl-edge) - var(--office-ctl-w) - 8px
      );
    }
  }
  .office-ctl:hover,
  .office-ctl:focus-visible,
  .office-ctl[aria-pressed='true'] {
    opacity: 1;
  }
  .office-ctl:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-radius: 0; /* the global :focus-visible rounds 3px — keep the pixel edge */
  }
  .office-ctl:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 rgba(0, 0, 0, 0.45);
  }
  .office-ctl svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }
  .office-ctl .office-ctl__play,
  .office-ctl[aria-pressed='true'] .office-ctl__pause {
    display: none;
  }
  .office-ctl[aria-pressed='true'] .office-ctl__play {
    display: block;
    color: var(--led);
  }
</style>

<script is:inline define:vars={{ wasmJsUrl: asset('wasm/pixtuoid_web.js') }}>
  (function () {
    const wrap = document.querySelector('.backdrop');
    const canvas = document.getElementById('office-live');
    if (!wrap || !canvas) return;
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    // The office needs WebAssembly, but the pause CONTROL does not: it governs
    // the page's wasm-independent ambient motion (statusline ticker, hero dust,
    // showcase clips) via pix:paused, so it must wire up and stay reachable even
    // on a no-wasm engine or a failed fetch. Only the office render path is gated
    // on `hasWasm`. #456
    const hasWasm = typeof WebAssembly !== 'undefined';

    // ── First-visit reveal (option A cover + Level-2 splash gate) ──────────────
    let revealStartSim = 0; // sim-clock t0 of the roll (pause freezes it via nowMs)
    let splashCleared = !!window.__pixRevealed; // seeded/repeat visit: already lifted
    // Option A: on the boot path, cover the baked poster with the canvas's own bg
    // tone (CSS background: var(--bg)) from the first paint, so the office reveals
    // straight into the live frame instead of cross-dissolving the wrong-time
    // still. Every non-boot path leaves it uncovered (the poster shows).
    function cover() {
      canvas.style.opacity = '1';
    }
    function uncover() {
      canvas.style.opacity = '0';
    }
    // Tell the boot splash the office boot has RESOLVED (came up, failed, or is
    // unsupported) so its Level-2 gate lifts — a flag, polled, so there's no
    // event-ordering race with the splash (Base.astro).
    function markEngineResolved() {
      window.__pixEngineReady = true;
    }
    // The roll is HELD until the boot splash clears, so it's never played hidden
    // behind the overlay. On a seeded/repeat visit pix:revealed already fired, so
    // splashCleared is already true and the office rolls in on the first paint.
    document.addEventListener('pix:revealed', function () {
      splashCleared = true;
    });
    if (hasWasm && !mq.matches) cover();
    else markEngineResolved(); // no office will boot → don't make the splash wait
    // ──────────────────────────────────────────────────────────────────────────

    // Render SMALL and let CSS stretch (image-rendering: pixelated): ~180px
    // tall is the app's own chunky-pixel scale (OFFICE_TARGET_H).
    const BUF_H = 180;
    const FRAME_MS = 33; // ~30fps cap
    // ONE office for the whole page (user-pinned): the hero's Dense variant
    // (seed 3 → two meeting rooms). One continuous world, one timeline that
    // never resets while you scroll — no per-floor swapping.
    const SEED = 3;
    // The office "rolls in" on the first live frame once the boot splash clears:
    // floors scroll up and decelerate (easeOutQuart) onto 6F, ghosting up out of
    // the bg-tone cover into the LIVE current-time frame — so the reveal shows the
    // correct-time office, never a cross-dissolve of the baked (evening) poster.
    // REVEAL_MS = roll length; FLOORS_PAST = how many floors scroll by;
    // CHROMA_SPLIT_PX = the faint CRT fringe at the start (set 0 to drop it).
    const REVEAL_MS = 1600;
    const FLOORS_PAST = 3.2;
    const CHROMA_SPLIT_PX = 3;

    let office = null;
    let wasm = null;
    let ctx2d = null;
    let img = null;
    let bufW = 0;
    let raf = 0;
    let last = 0;
    let live = false;
    // The pause switch (#office-pause). While paused the rAF loop is simply
    // not scheduled — the last frame stays on the canvas. `pauseOffset` is the
    // total user-paused time: the sim clock runs `Date.now() - pauseOffset`,
    // so resuming continues from the frozen moment instead of lurch-jumping
    // the timeline forward. (Tab-hidden stops take NO offset on purpose — the
    // office keeps living while you're away; only an explicit pause freezes
    // its clock. Cost: the engine's wall-clock day/night lags by the total
    // paused time — invisible at human pause scales.)
    const pauseBtn = document.getElementById('office-pause');
    let paused = false;
    let pauseOffset = 0;
    let pausedAt = 0;

    function sizeBuffer() {
      const w = window.innerWidth;
      const h = window.innerHeight;
      if (w < 1 || h < 1) return;
      bufW = Math.min(640, Math.max(64, Math.round((w / h) * BUF_H)));
      canvas.width = bufW;
      canvas.height = BUF_H;
      img = new ImageData(bufW, BUF_H);
    }

    function paint(nowMs) {
      office.step(nowMs, bufW, BUF_H);
      // Re-read ptr/len EVERY frame (resize reallocates; memory.grow
      // invalidates views) and copy into the reusable ImageData.
      const view = new Uint8ClampedArray(
        wasm.memory.buffer,
        office.frame_ptr(),
        office.frame_len()
      );
      if (view.length !== img.data.length) return;
      // First good frame = engine is up: release the boot splash's Level-2 gate.
      markEngineResolved();
      // Hold on the bg-tone cover until the boot splash has lifted, so the roll is
      // never played hidden behind the overlay (the office keeps stepping meanwhile).
      if (!splashCleared) return;
      if (!live) {
        live = true;
        revealStartSim = nowMs; // sim-clock t0 → pause freezes the roll too
        wrap.classList.add('is-live');
        document.dispatchEvent(new CustomEvent('pix:onair', { detail: { live: true } }));
      }
      const rt = mq.matches ? 1 : (nowMs - revealStartSim) / REVEAL_MS;
      if (rt < 1) {
        drawRevealFrame(view, rt < 0 ? 0 : rt);
      } else {
        img.data.set(view);
        ctx2d.putImageData(img, 0, 0);
      }
    }
    // The floor-roll: row y samples the office roll-offset rows up (same-floor, no
    // colour), alpha ramps from 0 so the bg tone shows through the fade-in and the
    // floor-seams, floors decelerate (easeOutQuart) onto 6F, a faint CRT
    // chroma-split converges. putImageData writes the sub-1 alpha straight to the
    // canvas — the element's own bg (var(--bg)) shows through transparent pixels.
    function drawRevealFrame(view, rt) {
      const w = bufW;
      const h = BUF_H;
      const d = img.data;
      const e = 1 - Math.pow(1 - rt, 4);
      const roll = Math.round((1 - e) * h * FLOORS_PAST);
      const alpha = Math.min(1, rt / 0.15);
      const split = Math.round((1 - e) * CHROMA_SPLIT_PX);
      for (let y = 0; y < h; y++) {
        const sy = (y + roll) % h;
        const seam = sy < 1 || sy > h - 2 ? 0.3 : 1; // floor divider: more bg shows
        const a = alpha * seam * 255;
        const row = sy * w;
        for (let x = 0; x < w; x++) {
          const o = (y * w + x) * 4;
          const xr = split ? (x + split < w ? x + split : w - 1) : x;
          const xb = split ? (x - split >= 0 ? x - split : 0) : x;
          d[o] = view[(row + xr) * 4];
          d[o + 1] = view[(row + x) * 4 + 1];
          d[o + 2] = view[(row + xb) * 4 + 2];
          d[o + 3] = a;
        }
      }
      ctx2d.putImageData(img, 0, 0);
    }

    function frame(t) {
      raf = 0;
      if (document.hidden) return;
      if (t - last >= FRAME_MS) {
        last = t;
        // Date.now(), NOT the rAF timestamp: the engine decodes now_ms as
        // calendar time (browser-local day/night + wall clock).
        paint(Date.now() - pauseOffset);
      }
      raf = requestAnimationFrame(frame);
    }
    function start() {
      if (!raf && office && !document.hidden && !mq.matches && !paused) {
        raf = requestAnimationFrame(frame);
      }
    }
    function stop() {
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    }
    function setPaused(p) {
      paused = p;
      if (pauseBtn) pauseBtn.setAttribute('aria-pressed', String(p));
      // fan the pause out to every OTHER >5s auto-motion surface — the statusline
      // feed ticker and the hero dust — so ONE control governs page motion
      // (WCAG 2.2.2 covers the whole page, not just this canvas).
      document.dispatchEvent(new CustomEvent('pix:paused', { detail: { paused: p } }));
      if (p) {
        pausedAt = Date.now();
        stop();
      } else {
        pauseOffset += Date.now() - pausedAt;
        start();
      }
    }
    if (pauseBtn) {
      pauseBtn.addEventListener('click', function () {
        setPaused(!paused);
      });
    }
    // #office-pause is visible whenever the page has ambient auto-motion to pause
    // — i.e. NOT reduced motion — regardless of whether the wasm office ever goes
    // live. On a no-wasm / fetch-fail load the ticker + dust + clips still run, so
    // the button must still offer their pause affordance (WCAG 2.2.2). #456
    function syncPauseBtn() {
      if (pauseBtn) pauseBtn.hidden = mq.matches;
    }
    syncPauseBtn();

    // .office-ctl's ≤960px clearance (above) reads --footer-h off the
    // footer's REAL rendered height instead of a flat guess — Footer.astro's
    // row wraps a different number of lines at different widths (measured 3
    // lines in the 360-460px band, not just the 2 the old flat offset
    // assumed), so only a live measurement clears every wrap. offsetHeight
    // reads 0 if the footer were ever display:none, which harmlessly
    // collapses the clearance to the desktop baseline via the calc's own gap
    // term rather than going stale. DEFERRED: this is:inline script renders
    // BEFORE <footer> (the parse-position trap already noted elsewhere in
    // this file) — a parse-time querySelector sees no footer yet.
    function wireFooterHeight() {
      const footerEl = document.querySelector('.footer');
      if (!footerEl) return;
      const root = document.documentElement;
      const syncFooterHeight = function () {
        root.style.setProperty('--footer-h', footerEl.offsetHeight + 'px');
      };
      syncFooterHeight();
      if ('ResizeObserver' in window) {
        new ResizeObserver(syncFooterHeight).observe(footerEl);
      } else {
        window.addEventListener('resize', syncFooterHeight);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wireFooterHeight, { once: true });
    } else {
      wireFooterHeight();
    }

    // Working Building: the 1F Install tabs are the surviving install-copy
    // control (wb-2: the statusline chip became a plain jump link and the
    // closer's own copy row was cut, both redundant with Install) — they hire
    // through ONE event instead of reaching for __pixHire directly. Answer
    // with pix:hired so the statusline can flash the receipt. The name
    // mirrors the hire cast's real identity (claude_code + cwd "/work/yours"
    // → label cc·yours — see pixtuoid-web/src/script.rs hire_beats). The
    // engine's own return value is the admission signal (`Office::hire`'s
    // bool contract) — the copy path never mirrors the concurrent cap on the
    // JS side, so the receipt can't drift from what the engine actually
    // admitted.
    document.addEventListener('pix:install-copy', function () {
      if (!window.__pixHire) return;
      if (!window.__pixHire()) return; // engine refused: cap reached or no free desk
      document.dispatchEvent(new CustomEvent('pix:hired', { detail: { name: 'cc·yours' } }));
    });

    // Reduced motion defers the wasm fetch entirely (still poster only) —
    // but a LIVE un-reduce should still bring the office up, so the fetch
    // lives behind a one-shot boot() the mq listener can trigger later.
    let booted = false;
    function boot() {
      if (booted) return;
      booted = true;
      // Showcase.astro's VIBING channel boots a SECOND Office off the SAME
      // wasm module. The generated glue's __wbg_init only memoizes the
      // RESOLVED instance (`if (wasm !== undefined) return wasm`), not the
      // in-flight promise — so two independent `mod.default()` calls racing
      // before either resolves would each instantiate a separate wasm
      // instance and stomp the one module-global `wasm`, leaving whichever
      // Office built against the losing instance reading the wrong linear
      // memory forever. Memoize ONE shared init promise on `window` so every
      // consumer awaits the same instantiation (site/CLAUDE.md VIBING entry).
      window.__pixWasm =
        window.__pixWasm ||
        import(wasmJsUrl).then(function (m) {
          return m.default().then(function () {
            return m;
          });
        });
      window.__pixWasm
        .then(function (mod) {
          // __wbg_init is idempotent once resolved, so this just hands back
          // the already-instantiated exports (no second fetch/instantiate).
          return mod.default().then(function (w) {
            wasm = w;
            office = new mod.Office(SEED);
            ctx2d = canvas.getContext('2d');
            sizeBuffer();
            start();
            // #434: the pix:install-copy listener above hires a coworker into
            // the background office (engine-capped at 3 concurrent; a no-op
            // before the first frame) and reads the admitted/refused bool
            // straight off the wasm call — the receipt event fires on THIS
            // return, not a JS-side guess at the engine's cap. A function
            // global, same idiom as __pixLights.
            window.__pixHire = function () {
              try {
                return office.hire();
              } catch (e) {
                return false; // never let a background flourish break the click
              }
            };
          });
        })
        .catch(function () {
          // wasm never loaded: drop the cover so the still poster shows, and
          // release the boot splash's gate (the engine won't be coming).
          uncover();
          markEngineResolved();
        });
    }
    // Defer the ~740KB wasm fetch OUT of the render-critical window: kick it
    // after `load`, at idle, so it stops competing with the above-fold poster /
    // fonts / CSS (LCP is the H1 text). The bg-tone cover holds until the first
    // frame lands (~0.5–1s later on fast links), then the office FLOOR-ROLLS in
    // once the boot splash clears (REVEAL_MS ramp) — a deliberate reveal, not a
    // silent swap. Reduced motion still defers entirely; a live un-reduce boots
    // promptly via the mq listener below.
    function deferBoot() {
      if (mq.matches) return;
      (
        window.requestIdleCallback ||
        function (fn) {
          return setTimeout(fn, 200);
        }
      )(boot);
    }
    if (hasWasm) {
      if (document.readyState === 'complete') deferBoot();
      else window.addEventListener('load', deferBoot, { once: true });
    }

    let rraf = 0;
    window.addEventListener('resize', function () {
      if (rraf) return;
      rraf = requestAnimationFrame(function () {
        rraf = 0;
        sizeBuffer();
        // Setting canvas.width WIPES the bitmap: while paused no loop will
        // repaint it, so re-render the ONE frozen frame at its frozen time.
        if (paused && live) paint(pausedAt - pauseOffset);
      });
    });
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) stop();
      else start();
    });
    if (mq.addEventListener) {
      mq.addEventListener('change', function () {
        if (mq.matches) {
          stop();
          // Reduced motion IS the poster-still design: nothing auto-animates, so
          // reset the pause flag (syncPauseBtn hides the control below).
          paused = false;
          if (pauseBtn) pauseBtn.setAttribute('aria-pressed', 'false');
          // clear any user-pause so the statusline feed / hero dust aren't stuck
          // paused after a later un-reduce (they hold their OWN reduced-motion
          // stop; this only keeps the pause flag in sync across surfaces)
          document.dispatchEvent(new CustomEvent('pix:paused', { detail: { paused: false } }));
          wrap.classList.remove('is-live');
          live = false;
          document.dispatchEvent(new CustomEvent('pix:onair', { detail: { live: false } }));
        } else if (hasWasm) {
          cover(); // re-cover before the fresh boot rolls the live office in
          boot(); // no-op if already booted; a reduced-motion first visit fetches here
          start();
        }
        // ambient motion stops on reduce and resumes on un-reduce (ticker/dust/
        // clips) — show/hide the control to match, both directions. #456
        syncPauseBtn();
      });
    }
  })();
</script>

<script is:inline>
  // THE DIMMER CONTROLLER — scrolling is the light switch. One rAF loop,
  // one style.opacity write per changed frame (compositor-only; no CSS-var
  // recalc, no backdrop-filter). Every [data-lit] block pulls darkness in
  // as it approaches the viewport center — text and dusk arrive as ONE
  // gesture — and releases it in the observation gaps (dim → 0, the office
  // alone is the content).
  (function () {
    const dimmer = document.getElementById('dimmer');
    if (!dimmer) return;
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const DIM_MAX = 0.86;

    let blocks = []; // cached page-space rects; re-measured on resize/body-reflow
    let lastY = -1;
    let lastOp = -1;
    let raf = 0;
    let active = null; // the currently-faded [data-lit] block

    // smoothstep — darkness eases in/out with approach, no linear pop
    function ease(t) {
      return t * t * (3 - 2 * t);
    }

    // The shared compute-and-apply step, driven by EITHER the per-frame scroll
    // check (frame(), below) or a fresh measure() (re-measure paths, further
    // down). A content reflow ABOVE the viewport (e.g. a Showcase channel
    // swap) shrinks/grows the page and the browser's own scroll anchoring
    // adjusts window.scrollY IMMEDIATELY, in the SAME task — before this
    // controller's re-measure ever runs. If that re-measure were merely
    // deferred (invalidate blocks, let the NEXT frame() tick recompute), the
    // rAF that already ran THIS frame paints one wrong frame first (a real,
    // reproducible glitch: scroll-anchor-adjusted y against stale pre-reflow
    // blocks briefly select the wrong [data-lit] block). Re-measure calling
    // this SAME function synchronously means the corrected write lands in the
    // same task, before paint — the wrong value is never on screen.
    function recompute(y) {
      lastY = y;
      const center = y + window.innerHeight / 2;
      const reach = window.innerHeight * 0.55; // how far a block throws shade
      let best = 0;
      let bestEl = null;
      for (let i = 0; i < blocks.length; i++) {
        const b = blocks[i];
        const d = center < b.top ? b.top - center : center > b.bottom ? center - b.bottom : 0;
        const p = d >= reach ? 0 : 1 - d / reach;
        if (p > best) {
          best = p;
          bestEl = b.el;
        }
      }
      // A block may cap its own darkness below DIM_MAX via data-lit-max: the
      // hero holds a lower ceiling so the LIVE office (the product's one true
      // trick) actually reads above the fold, while the downpage statement
      // holds keep DIM_MAX for copy legibility. The [data-lit]::before radial
      // wash still floors local contrast on the capped block.
      const cap = bestEl && bestEl.dataset.litMax ? parseFloat(bestEl.dataset.litMax) : DIM_MAX;
      const op = cap * ease(best);
      if (Math.abs(op - lastOp) > 0.002) {
        lastOp = op;
        dimmer.style.opacity = op.toFixed(3);
        // Polled global, deliberately NOT an event (contrast pix:onair): a
        // continuous per-frame value is read at the consumer's own cadence
        // (the statusline polls); a discrete flip gets an event + class seed.
        window.__pixLights = op;
      }
      // The lit block itself rises with the darkness (opt-in via
      // data-lit="fade"); only the active block + the one it replaces are
      // ever written.
      if (bestEl !== active) {
        if (active && active.getAttribute('data-lit') === 'fade') {
          active.style.opacity = '0.001';
        }
        active = bestEl;
      }
      if (active && active.getAttribute('data-lit') === 'fade') {
        const t = ease(best);
        active.style.opacity = (0.15 + 0.85 * t).toFixed(3);
        active.style.transform = 'translateY(' + Math.round(24 * (1 - t)) + 'px)';
      }
    }

    function measure() {
      const y = window.scrollY;
      blocks = Array.prototype.map.call(document.querySelectorAll('[data-lit]'), function (el) {
        const r = el.getBoundingClientRect();
        return { el, top: r.top + y, bottom: r.bottom + y };
      });
      recompute(y); // same task, before paint — see recompute()'s comment
    }

    function frame() {
      raf = 0;
      const y = window.scrollY;
      if (y !== lastY) recompute(y);
      raf = requestAnimationFrame(frame);
    }

    // Re-measure listeners are registered UNCONDITIONALLY (not behind the
    // reduced-motion gate): a page loaded reduced then un-reduced mid-session
    // must not run the controller forever on the single stale snapshot the
    // un-reduce branch measured — every subsequent resize/rotation/late layout
    // shift has to re-measure the page-space rects. (measure() is a cheap
    // getBoundingClientRect sweep; harmless when no loop is running.)
    let rraf = 0;
    window.addEventListener('resize', function () {
      if (rraf) return;
      rraf = requestAnimationFrame(function () {
        rraf = 0;
        measure();
      });
    });
    // content below (boot reveal, lazy media) can shift rects after load
    window.addEventListener('load', measure);
    // A Showcase channel tune swaps stages of different heights, shifting the
    // page-space top/bottom of the blocks below it (#install) — resize/load
    // alone miss that. Call measure() DIRECTLY here (no rAF deferral, unlike
    // the plain resize listener above): ResizeObserver notifications land in
    // the SAME task as the reflow that triggered them, and measure() now
    // recomputes synchronously (see recompute()'s comment) — deferring this
    // one frame is exactly what let the stale-block glitch reach the screen.
    if ('ResizeObserver' in window) {
      new ResizeObserver(measure).observe(document.body);
    }

    function wire() {
      if (mq.matches) return; // reduced motion: CSS holds the static level
      measure();
      raf = requestAnimationFrame(frame);
    }
    // DEFERRED: this is:inline script renders BEFORE <main> — a parse-time
    // querySelectorAll sees zero [data-lit] blocks (the documented
    // parse-position trap).
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wire, { once: true });
    } else {
      wire();
    }
    if (mq.addEventListener) {
      mq.addEventListener('change', function () {
        if (mq.matches && raf) {
          cancelAnimationFrame(raf);
          raf = 0;
          dimmer.style.opacity = ''; // CSS reduced-motion rule takes over
          // also release the faded [data-lit="fade"] block, or the hero copy
          // stays STRANDED at inline opacity 0.001 (invisible h1/CTA) with no
          // recovery while reduce stays on — an inline declaration beats the CSS
          // parallel design (mirrors the dimmer reset just above).
          // Reset EVERY faded block, not just `active`: if you scrolled past the
          // hero into Showcase/Install BEFORE enabling reduce, the hero is parked
          // at opacity 0.001 but `active` is now #showcase/#install — so resetting
          // only `active` leaves the hero H1/CTA invisible with no recovery.
          document.querySelectorAll('[data-lit="fade"]').forEach(function (el) {
            el.style.opacity = '';
            el.style.transform = '';
          });
          active = null;
        } else if (!mq.matches && !raf) {
          measure();
          raf = requestAnimationFrame(frame);
        }
      });
    }
  })();
</script>
