---
import features from '../features.json';

// Single source of truth: site/src/features.json — the SAME list the README
// Features table is generated from (scripts/gen-readme.mjs), so the
// two can't drift. The bento shows the items that carry `card` metadata; cards
// deep-link into the Studio Wall channel that demos them live.
const cells = features.flatMap((f) =>
  f.card
    ? [
        {
          icon: f.icon,
          title: f.name,
          body: f.card.blurb ?? f.desc,
          href: f.card.href,
        },
      ]
    : []
);
---

<section id="features" class="features" data-lit data-floor="4">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">4F · amenities — the office is alive</p>
      <h2 class="statement statement--md">Not a dashboard.<br />A little world.</h2>
      <p class="lead">
        pixtuoid renders your agents as coworkers in a top-down pixel office — with the small
        touches that make it worth glancing at.
      </p>
    </div>

    <div class="ledger">
      {
        cells.map((c) => (
          <article class="ledger__row reveal">
            <span class="ledger__icon" aria-hidden="true">
              {c.icon}
            </span>
            <h3 class="ledger__name">{c.title}</h3>
            <p class="ledger__body">{c.body}</p>
            {c.href && (
              <a class="ledger__link" href={c.href}>
                see it live →
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* the typographic ledger: no cards, no borders — rows of type sitting
     directly on the dimmed office */
  .ledger {
    margin-top: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
  }
  .ledger__row {
    display: grid;
    grid-template-columns: 2.2rem minmax(12rem, 18rem) 1fr auto;
    gap: 0.4rem 1.4rem;
    align-items: baseline;
  }
  .ledger__icon {
    font-size: 1.2rem;
  }
  .ledger__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-synthesis: none;
    font-size: 1.65rem;
    margin: 0;
  }
  .ledger__body {
    font-family: var(--font-body);
    margin: 0;
    color: var(--fg-muted);
  }
  .ledger__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--coral);
    text-decoration: none;
    white-space: nowrap;
  }
  .ledger__link:hover {
    color: var(--coral-deep);
  }
  @media (max-width: 860px) {
    .ledger__row {
      grid-template-columns: 2.2rem 1fr;
    }
    .ledger__body,
    .ledger__link {
      grid-column: 2;
    }
  }
</style>
