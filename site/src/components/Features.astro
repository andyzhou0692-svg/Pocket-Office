---
import featuresData from '../features.json';
import { floorById, floorName } from '../consts';
import PixIcon from './PixIcon.astro';

const floor = floorById('features');

// A feature card MAY deep-link to the Studio Wall channel that demos it
// (`card.href`); the 4F "small touches" cards don't — their subjects aren't
// showcase channels — so no current card carries an href. `Feature` keeps that
// field optional so `f.card.href` stays type-safe without a per-access cast.
type Feature = {
  icon: string;
  name: string;
  desc: string;
  featured?: boolean;
  pix?: string;
  card?: { blurb: string; href?: string };
};

// Single source of truth: site/src/features.json — the SAME list the README
// Features table is generated from (scripts/gen-readme.mjs), so the two can't drift.
// The bento shows the items that carry `card` metadata.
const features: Feature[] = featuresData;
const cells = features.flatMap((f) =>
  f.card
    ? [
        {
          icon: f.icon,
          pix: f.pix,
          title: f.name,
          body: f.card.blurb ?? f.desc,
          href: f.card.href,
        },
      ]
    : []
);
---

<section
  id={floor.id}
  class="features"
  data-lit
  data-floor={floor.fl}
  data-floor-label={floor.label}
>
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{floor.fl} · {floorName(floor)} — the office is alive</p>
      <h2 class="statement statement--md">Not a dashboard.<br />A little world.</h2>
      <p class="lead">
        pixtuoid renders your agents as coworkers in a top-down pixel office — with the small
        touches that make it worth glancing at.
      </p>
    </div>

    <div class="ledger text-scrim">
      {
        cells.map((c) => (
          <article class="ledger__row reveal">
            <span class="ledger__icon" aria-hidden="true">
              {c.pix ? <PixIcon name={c.pix} scale={2} /> : c.icon}
            </span>
            <h3 class="ledger__name">{c.title}</h3>
            <p class="ledger__body">{c.body}</p>
            {c.href && (
              <a class="ledger__link" href={c.href}>
                see it live{' '}
                <span class="ledger__arrow" aria-hidden="true">
                  →
                </span>
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Bare over the live office (no plate) — matches the SupportedTools compat-
     table look. The shared .lead's --fg-muted measured short of WCAG AA here
     (day worst-case 3.79:1, centered at the section's own 0.86 dimmer cap);
     --office-ink clears it (day/night both ≥6.8:1) without a plate. Scoped to
     this section only — every OTHER section's .lead stays --fg-muted. */
  #features .section-head .lead {
    color: var(--office-ink);
  }
  /* the ledger is ONE bordered .text-scrim plate (not 7 separate per-row
     cards — tried both; individual boxes read heavy/repetitive, one sheet
     with hairline row dividers reads as a single ledger, matching the name),
     wrapping typographic rows with no per-row background of their own. */
  .ledger {
    margin-top: 1.6rem;
    display: flex;
    flex-direction: column;
    /* horizontal padding/margin-inline stay the base .text-scrim values
       (0.75em / -0.75em) — they already cancel out so the row icons stay
       left-aligned with the section head above. A wider override here
       overflowed past the container's own padding at 390px (the border
       rendered off-screen) — only vertical breathing room is wrapper-local. */
    padding-block: 0.4rem;
  }
  .ledger__row {
    display: grid;
    grid-template-columns: 2.2rem minmax(12rem, 18rem) 1fr auto;
    gap: 0.4rem 1.4rem;
    align-items: baseline;
    padding: 1.3rem 0;
  }
  .ledger__row:not(:last-child) {
    border-bottom: 1px solid var(--border);
  }
  .ledger__icon {
    font-size: 1.2rem;
  }
  .ledger__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-synthesis: none;
    font-size: 1.65rem;
    margin: 0;
  }
  .ledger__body {
    font-family: var(--font-body);
    margin: 0;
    color: var(--fg-muted);
  }
  .ledger__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--coral-deep); /* AA 5.2:1; plain --coral was ~2.7:1 on day */
    text-decoration: none;
    white-space: nowrap;
  }
  /* color-based hover was a no-op (rest is already --coral-deep, and night's
     a:not(.btn) outranks it) — move the arrow instead: an AA-safe tell that
     works in both themes without dropping contrast. */
  .ledger__arrow {
    display: inline-block;
    transition: transform 0.18s ease;
  }
  .ledger__link:hover .ledger__arrow,
  .ledger__link:focus-visible .ledger__arrow {
    transform: translateX(3px);
  }
  @media (max-width: 860px) {
    .ledger__row {
      grid-template-columns: 2.2rem 1fr;
    }
    .ledger__body,
    .ledger__link {
      grid-column: 2;
    }
  }
</style>
