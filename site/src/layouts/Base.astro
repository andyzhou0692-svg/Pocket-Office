---
import '../styles/global.css';
import { asset } from '../consts';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'pixtuoid — your coding agents, alive in a pixel office',
  description = 'A terminal-native pixel-art office that visualizes your AI coding agents (Claude Code, Codex, and more) as little animated coworkers — day/night lighting, weather, themes, and pets included.',
} = Astro.props;

// Use asset() (base-path-safe) for internal URLs; BASE_URL has no trailing
// slash, so raw `${base}favicon.svg` would emit `/pixtuoidfavicon.svg` (404).
const favicon = asset('favicon.svg');
// Absolute URLs for crawlers (Astro.site is the deploy origin).
const SITE = Astro.site ?? new URL('https://ivanwng97.github.io');
const ogImage = new URL(asset('demos/hero-poster.png'), SITE).href;
const canonical = new URL(asset(''), SITE).href;
const version = __PIXTUOID_VERSION__; // from the workspace Cargo.toml at build
---

<!doctype html>
<html lang="en" data-theme="day">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#faf9f5" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Pixelify Sans (pixel display) + JetBrains Mono (UI/code) + Lora (warm body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Lora:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- No-FOUC theme init: ?theme= override → saved choice → system → day -->
    <script is:inline>
      (function () {
        try {
          const ok = function (v) {
            return v === 'day' || v === 'night' || v === 'dracula';
          };
          const forced = new URLSearchParams(location.search).get('theme');
          const pick = ok(forced) ? forced : localStorage.getItem('pix-theme');
          const sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'night' : 'day';
          document.documentElement.dataset.theme = ok(pick) ? pick : sys;
        } catch (e) {
          document.documentElement.dataset.theme = 'day';
        }
      })();
    </script>

    <!-- show the boot intro once per session (skip for reduced-motion) -->
    <script is:inline>
      try {
        if (
          !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
          !sessionStorage.getItem('pix-booted')
        ) {
          document.documentElement.dataset.booting = '1';
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <div class="cursor-glow" aria-hidden="true"></div>

    <div id="boot" class="boot" role="status" aria-label="Loading pixtuoid">
      <div class="boot__log">
        <div class="boot__line">pixtuoid <b>v{version}</b></div>
        <div class="boot__line">▸ booting office… <span class="boot__ok">ok</span></div>
        <div class="boot__line">▸ loading themes… <span class="boot__ok">ok</span></div>
        <div class="boot__line">▸ spawning agents… <span class="boot__ok">ok</span></div>
        <div class="boot__line">▸ ready<span class="cursor" aria-hidden="true"></span></div>
      </div>
      <div class="boot__hint">press any key to skip</div>
    </div>

    <slot />

    <!-- reveal-on-scroll: one orchestrated entrance per section -->
    <script is:inline>
      (function () {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = document.querySelectorAll('.reveal');
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach(function (el) {
            el.classList.add('in');
          });
          return;
        }
        const io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>

    <!-- FX: pointer glow + 3D tilt, CRT power-on, and a `dracula` easter egg -->
    <script is:inline>
      (function () {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const fine = window.matchMedia('(pointer: fine)').matches;

        if (fine && !reduce) {
          const tilts = document.querySelectorAll('.tilt');
          let raf = 0,
            px = 0,
            py = 0;
          document.addEventListener('pointermove', function (e) {
            px = e.clientX;
            py = e.clientY;
            if (raf) return;
            raf = requestAnimationFrame(function () {
              raf = 0;
              document.body.classList.add('has-pointer');
              document.body.style.setProperty('--mx', px + 'px');
              document.body.style.setProperty('--my', py + 'px');
              tilts.forEach(function (el) {
                const r = el.getBoundingClientRect();
                if (!r.width) return;
                const dx = (px - (r.left + r.width / 2)) / (r.width / 2);
                const dy = (py - (r.top + r.height / 2)) / (r.height / 2);
                const near = Math.abs(dx) < 1.6 && Math.abs(dy) < 1.6;
                el.style.setProperty('--rx', (near ? dx * 4 : 0).toFixed(2) + 'deg');
                el.style.setProperty('--ry', (near ? -dy * 4 : 0).toFixed(2) + 'deg');
              });
            });
          });
        }

        if (!reduce && 'IntersectionObserver' in window) {
          const co = new IntersectionObserver(
            function (es) {
              es.forEach(function (e) {
                if (e.isIntersecting) {
                  e.target.classList.add('crt-on');
                  co.unobserve(e.target);
                }
              });
            },
            { threshold: 0.3 }
          );
          document.querySelectorAll('.crt:not(.crt-manual)').forEach(function (el) {
            co.observe(el);
          });
        }

        function clearRetint() {
          const s = document.documentElement.style;
          s.removeProperty('--coral');
          s.removeProperty('--coral-deep');
          s.removeProperty('--amber');
        }
        let buf = '';
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            clearRetint();
            let saved = null;
            try {
              saved = localStorage.getItem('pix-theme');
            } catch (e2) {}
            document.documentElement.dataset.theme = saved || 'day';
            return;
          }
          if (e.key && e.key.length === 1) {
            buf = (buf + e.key.toLowerCase()).slice(-7);
            if (buf.indexOf('dracula') !== -1) {
              clearRetint();
              document.documentElement.dataset.theme = 'dracula';
            }
          }
        });
      })();
    </script>

    <!-- boot intro sequence → dispatches `pix:revealed` (immediately if skipped/disabled) -->
    <script is:inline>
      (function () {
        const root = document.documentElement;
        const boot = document.getElementById('boot');
        function reveal() {
          document.dispatchEvent(new Event('pix:revealed'));
        }
        if (root.dataset.booting !== '1' || !boot) {
          reveal();
          return;
        }
        const lines = boot.querySelectorAll('.boot__line');
        let i = 0,
          done = false;
        function finish() {
          if (done) return;
          done = true;
          boot.classList.add('is-done');
          try {
            sessionStorage.setItem('pix-booted', '1');
          } catch (e) {}
          setTimeout(function () {
            root.removeAttribute('data-booting');
          }, 460);
          boot.removeEventListener('click', skip);
          document.removeEventListener('keydown', onKey);
          reveal();
        }
        function step() {
          if (i < lines.length) {
            lines[i].classList.add('in');
            i++;
            setTimeout(step, 175);
          } else {
            setTimeout(finish, 380);
          }
        }
        function skip() {
          for (let j = 0; j < lines.length; j++) lines[j].classList.add('in');
          finish();
        }
        function onKey() {
          skip();
        }
        setTimeout(step, 140);
        boot.addEventListener('click', skip);
        document.addEventListener('keydown', onKey);
      })();
    </script>
  </body>
</html>
