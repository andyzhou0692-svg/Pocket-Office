---
import { getCollection, render } from 'astro:content';
import Docs from '../layouts/Docs.astro';

// Rendered from docs/MIGRATION.md (the single source) — there's one entry.
const [entry] = await getCollection('migration');
if (!entry) {
  throw new Error(
    'migration.astro: the "migration" collection is empty — is docs/MIGRATION.md present and matched by the glob loader in content.config.ts?'
  );
}
const { Content, headings } = await render(entry);
---

<Docs
  title="Migration — pixtuoid"
  description="Migrating from ascii-agents (v0.3.x → v0.4.0) — the rename, hooks re-registration, and config paths."
  headings={headings}
  current="migration"
  sourcePath="docs/MIGRATION.md"
>
  <Content />
</Docs>
