---
import { getCollection, render } from 'astro:content';
import Docs from '../layouts/Docs.astro';

// Rendered from docs/CONFIGURATION.md (the single source) — there's one entry.
const [entry] = await getCollection('docs');
if (!entry) {
  throw new Error(
    'config.astro: the "docs" collection is empty — is docs/CONFIGURATION.md present and matched by the glob loader in content.config.ts?'
  );
}
const { Content, headings } = await render(entry);
---

<Docs
  title="Configuration — Pocket Office"
  description="Configure Pocket Office: config.toml keys, themes, and custom sprite packs."
  headings={headings}
  current="config"
  sourcePath="docs/CONFIGURATION.md"
>
  <Content />
</Docs>
