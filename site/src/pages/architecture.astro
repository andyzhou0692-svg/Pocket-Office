---
import { getCollection, render } from 'astro:content';
import Docs from '../layouts/Docs.astro';

// Rendered from docs/ARCHITECTURE.md (the single source) — there's one entry.
const [entry] = await getCollection('architecture');
if (!entry) {
  throw new Error(
    'architecture.astro: the "architecture" collection is empty — is docs/ARCHITECTURE.md present and matched by the glob loader in content.config.ts?'
  );
}
const { Content, headings } = await render(entry);
---

<Docs
  title="Architecture — pixtuoid"
  description="How pixtuoid turns a running coding-agent session into a moving sprite: the producer → reducer → renderer pipeline across four Rust crates."
  headings={headings}
  current="architecture"
  sourcePath="docs/ARCHITECTURE.md"
  sourceNote="this page renders it verbatim (the diagram is the same Mermaid block GitHub shows)."
>
  <Content />
</Docs>
