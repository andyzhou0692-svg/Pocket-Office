---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { REPO, asset } from '../consts';

// Rendered from docs/ARCHITECTURE.md (the single source) — there's one entry.
const [entry] = await getCollection('architecture');
if (!entry) {
  throw new Error(
    'architecture.astro: the "architecture" collection is empty — is docs/ARCHITECTURE.md present and matched by the glob loader in content.config.ts?'
  );
}
const { Content } = await render(entry);
---

<Base
  title="Architecture — pixtuoid"
  description="How pixtuoid turns a running coding-agent session into a moving sprite: the producer → reducer → renderer pipeline across three Rust crates."
>
  <Nav />
  <main id="main" tabindex="-1" class="config">
    <p class="config__back"><a href={asset('')}>← back to pixtuoid</a></p>
    <article class="prose reveal">
      <Content />
    </article>
    <p class="config__source">
      Source of truth:
      <a href={`${REPO}/blob/main/docs/ARCHITECTURE.md`} target="_blank" rel="noreferrer">
        docs/ARCHITECTURE.md
      </a> — this page renders it verbatim (the diagram is the same Mermaid block GitHub shows).
    </p>
  </main>
  <Footer />
</Base>

<style>
  .config {
    width: 100%;
    max-width: 820px;
    margin-inline: auto;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.1rem, 4vw, 2.5rem) clamp(3rem, 7vw, 5rem);
  }
  .config__back {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }
  .config__back a {
    color: var(--fg-muted);
    text-decoration: none;
  }
  .config__back a:hover {
    color: var(--coral-deep);
  }
  .config__source {
    margin-top: 2.6rem;
    padding-top: 1.3rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.84rem;
    color: var(--fg-muted);
  }
</style>
